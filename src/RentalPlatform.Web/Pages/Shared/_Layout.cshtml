@{
    var title = ViewData["Title"] as string ?? "RentalPlatform";
    var htmlLang = (ViewData["HtmlLang"] as string ?? "en").ToLowerInvariant();
    var htmlClass = ViewData["HtmlClass"] as string ?? string.Empty;
    var bodyClass = ViewData["BodyClass"] as string ?? "bg-background text-on-background antialiased min-h-screen";
    var frontNavVariant = (ViewData["FrontNavVariant"] as string ?? string.Empty).ToLowerInvariant();
    var frontActiveNav = (ViewData["FrontActiveNav"] as string ?? string.Empty).ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="@htmlLang" class="@htmlClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
    </style>
    @RenderSection("Head", required: false)
</head>
<body class="@bodyClass">
    @if (frontNavVariant == "auth")
    {
        <header class="w-full sticky top-0 z-50 bg-surface-container-lowest border-b border-outline-variant shadow-sm">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-md flex items-center justify-between">
                <a class="text-headline-md font-headline-md font-bold text-primary flex items-center gap-2" asp-page="/Index">
                    <span class="material-symbols-outlined text-[22px]">home</span>
                    RentalPlatform
                </a>
                <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-colors" asp-page="/Index">
                    Explore stays
                </a>
            </div>
        </header>
    }
    else if (frontNavVariant == "guest" || frontNavVariant == "owner")
    {
        @await Html.PartialAsync("~/Pages/Front/Shared/_FrontNavigation.cshtml")
    }
    else
    {
        @await Html.PartialAsync("~/Pages/Front/Shared/_FrontNavigation.cshtml")
    }
    <main class="flex-1">
        @RenderBody()
    </main>
    @RenderSection("Scripts", required: false)
</body>
</html>
