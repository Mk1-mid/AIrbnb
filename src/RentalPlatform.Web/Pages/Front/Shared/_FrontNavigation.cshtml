@inject RentalPlatform.Application.Interfaces.INotificationService NotificationService
@using System.Security.Claims
@{
    var variant = (ViewData["FrontNavVariant"] as string ?? "public").ToLowerInvariant();
    var active = (ViewData["FrontActiveNav"] as string ?? string.Empty).ToLowerInvariant();

    string NavClass(string key, string baseClass, string activeClass = "") =>
        active == key ? $"{baseClass} {activeClass}" : baseClass;

    var unreadCount = 0;
    if (User?.Identity?.IsAuthenticated == true)
    {
        var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("sub")?.Value;
        if (Guid.TryParse(userIdClaim, out var userId))
        {
            unreadCount = NotificationService.GetUnreadCountAsync(userId).GetAwaiter().GetResult();
        }
    }

    var isOwner = variant == "owner";
    var isGuest = variant == "guest";
    var isAuth = variant == "auth";
}

@if (isAuth)
{
    <header class="sticky top-0 z-50 border-b border-primary/15 bg-background/80 backdrop-blur-xl">
        <div class="max-w-container-max mx-auto flex items-center justify-between px-margin-mobile md:px-margin-desktop py-md">
            <a class="flex items-center gap-2 text-headline-md font-headline-md text-primary tracking-wide" asp-page="/Front/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <div class="hidden md:flex items-center gap-lg">
                <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-all duration-300 uppercase tracking-widest" asp-page="/Front/Index">Discover</a>
                <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-all duration-300 uppercase tracking-widest" asp-page="/Front/SignIn">Sign In</a>
            </div>
        </div>
    </header>
}
else if (isGuest || isOwner)
{
    var navItems = variant == "owner"
        ? new[]
        {
            ("dashboard", "Dashboard", "/Front/OwnerDashboard", "dashboard"),
            ("properties", "Mis inmuebles", "/Front/OwnerProperties", "home"),
            ("publish", "Publicar inmueble", "/Front/PublishEditProperty", "add_box"),
            ("reports", "Reportes", "/Front/OwnerReports", "summarize"),
        }
        : new[]
        {
            ("browse", "Explorar", "/Front/Index", "search"),
            ("reservations", "Mis reservas", "/Front/GuestReservations", "event_note"),
            ("favorites", "Favoritos", "/Front/GuestFavorites", "favorite"),
            ("notifications", "Notificaciones", "/Front/GuestNotifications", "notifications"),
            ("verification", "Verificación", "/Front/IdentityVerification", "badge"),
        };

    <header class="md:hidden sticky top-0 z-50 w-full border-b border-primary/15 bg-background/80 backdrop-blur-xl">
        <div class="flex items-center justify-between px-margin-mobile py-md">
            <a class="flex items-center gap-2 text-headline-md font-headline-md text-primary tracking-wide" asp-page="/Front/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <button type="button" class="text-on-surface-variant hover:text-primary transition-all duration-300" aria-label="Open navigation">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </header>

    <aside class="hidden md:flex flex-col fixed left-0 top-0 z-40 h-screen w-64 gap-stack-sm border-r border-primary/10 bg-surface-container-lowest/80 px-md py-xl backdrop-blur-2xl">
        <div class="mb-lg flex items-center gap-stack-sm">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-primary/30 bg-primary/10 text-primary">
                <span class="material-symbols-outlined">home</span>
            </div>
            <div>
                <div class="text-headline-md font-headline-md leading-tight text-primary">LuxeStay</div>
                <div class="text-label-sm font-label-sm uppercase tracking-widest text-on-surface-variant">Nocturne Elite</div>
            </div>
        </div>

        <nav class="flex flex-col gap-xs">
            @foreach (var item in navItems)
            {
                var linkClass = NavClass(
                    item.Item1,
                    "flex items-center gap-3 rounded-lg px-4 py-2 text-label-md font-label-md text-on-surface-variant transition-all duration-300 hover:bg-primary/5 hover:text-primary hover:translate-x-1",
                    "border border-primary/20 bg-primary/5 text-primary shadow-[0_0_15px_rgba(242,202,80,0.08)]"
                );
                <a class="@linkClass" asp-page="@item.Item3">
                    <span class="material-symbols-outlined text-[20px]">@item.Item4</span>
                    @item.Item2
                </a>
            }
        </nav>
        @if (isGuest && unreadCount > 0)
        {
            <div class="mt-auto border-t border-outline-variant/10 pt-4">
                <div class="flex items-center gap-3 px-4 py-2 text-on-surface-variant">
                    <span class="material-symbols-outlined text-[20px]">notifications</span>
                    <span class="text-label-md font-label-md">Notificaciones</span>
                    <span class="ml-auto rounded-full bg-primary text-on-primary px-2 py-0.5 text-label-sm font-label-sm">@unreadCount</span>
                </div>
            </div>
        }
    </aside>
}
else
{
    <nav class="sticky top-0 z-50 w-full border-b border-primary/15 bg-background/80 backdrop-blur-xl">
        <div class="mx-auto flex w-full max-w-container-max items-center justify-between px-margin-mobile py-md md:px-margin-desktop">
            <a class="flex items-center gap-2 text-headline-md font-headline-md text-primary tracking-wide" asp-page="/Front/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <div class="hidden items-center gap-lg md:flex">
                <a class="border-b-2 border-primary pb-1 text-label-md font-label-md text-primary uppercase tracking-widest" asp-page="/Front/Index">Discover</a>
                <a class="text-label-md font-label-md text-on-surface-variant uppercase tracking-widest transition-all duration-300 hover:text-primary" asp-page="/Front/GuestFavorites">Favorites</a>
                <a class="text-label-md font-label-md text-on-surface-variant uppercase tracking-widest transition-all duration-300 hover:text-primary" asp-page="/Front/SignIn">Sign In</a>
            </div>
        </div>
    </nav>
}
