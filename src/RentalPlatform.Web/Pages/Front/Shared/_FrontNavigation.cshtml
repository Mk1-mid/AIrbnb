@inject RentalPlatform.Application.Interfaces.INotificationService NotificationService
@using System.Security.Claims
@{
    var variant = (ViewData["FrontNavVariant"] as string ?? "public").ToLowerInvariant();
    var active = (ViewData["FrontActiveNav"] as string ?? string.Empty).ToLowerInvariant();

    string NavClass(string key, string baseClass, string activeClass = "") =>
        active == key ? $"{baseClass} {activeClass}" : baseClass;

    var unreadCount = 0;
    if (User.Identity.IsAuthenticated)
    {
        var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("sub")?.Value;
        if (Guid.TryParse(userIdClaim, out var userId))
        {
            unreadCount = NotificationService.GetUnreadCountAsync(userId).GetAwaiter().GetResult();
        }
    }
}

@if (variant == "auth")
{
    <header class="w-full sticky top-0 z-50 bg-surface-container-lowest border-b border-outline-variant shadow-sm">
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-md flex items-center justify-between">
            <a class="text-headline-md font-headline-md font-bold text-primary flex items-center gap-2" asp-page="/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-colors" asp-page="/Index">
                Explore stays
            </a>
        </div>
    </header>
}
else if (variant == "guest" || variant == "owner")
{
    var navItems = variant == "owner"
        ? new[]
        {
            ("dashboard", "Dashboard", "/Front/OwnerDashboard", "dashboard"),
            ("properties", "Mis inmuebles", "/Front/OwnerProperties", "home"),
            ("publish", "Publicar inmueble", "/Front/PublishEditProperty", "add_box"),
            ("reports", "Reportes", "/Front/OwnerReports", "summarize"),
        }
        : new[]
        {
            ("browse", "Explorar", "/Index", "search"),
            ("reservations", "Mis reservas", "/Front/GuestReservations", "event_note"),
            ("favorites", "Favoritos", "/Front/GuestFavorites", "favorite"),
            ("notifications", "Notificaciones", "/Front/GuestNotifications", "notifications"),
            ("verification", "Verificación", "/Front/IdentityVerification", "badge"),
        };

    <header class="md:hidden w-full sticky top-0 z-50 bg-surface-container-lowest border-b border-outline-variant shadow-sm">
        <div class="px-margin-mobile py-stack-md flex items-center justify-between">
            <a class="text-headline-md font-headline-md font-bold text-primary flex items-center gap-2" asp-page="/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <button type="button" class="text-on-surface-variant">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </header>

    <aside class="hidden md:flex flex-col h-screen w-64 fixed left-0 top-0 bg-surface-container-low p-stack-md gap-stack-sm z-40 border-r border-outline-variant/30">
        <div class="flex items-center gap-stack-sm p-stack-sm mb-stack-md">
            <div class="w-10 h-10 rounded-xl bg-primary text-on-primary flex items-center justify-center">
                <span class="material-symbols-outlined">home</span>
            </div>
            <div>
                <div class="text-headline-md font-headline-md text-primary leading-tight">LuxeStay</div>
                <div class="text-label-sm font-label-sm text-on-surface-variant">Rental platform</div>
            </div>
        </div>

        <nav class="flex flex-col gap-base">
            @foreach (var item in navItems)
            {
                var linkClass = NavClass(item.Item1, "flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md", "bg-secondary-container text-on-secondary-container font-bold");
                <a class="@linkClass" asp-page="@item.Item3">
                    <span class="material-symbols-outlined text-[20px]">@item.Item4</span>
                    @item.Item2
                </a>
            }
        </nav>
        @if (variant == "guest" && unreadCount > 0)
        {
            <div class="mt-auto pt-4 border-t border-outline-variant/30">
                <div class="flex items-center gap-3 px-4 py-2 text-on-surface-variant">
                    <span class="material-symbols-outlined text-[20px]">notifications</span>
                    <span class="text-label-md font-label-md">Notificaciones</span>
                    <span class="ml-auto bg-error text-on-error text-label-sm font-label-sm px-2 py-0.5 rounded-full">@unreadCount</span>
                </div>
            </div>
        }
    </aside>
}
else
{
    <nav class="bg-surface-container-lowest w-full top-0 sticky border-b border-outline-variant shadow-sm z-50">
        <div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-stack-md max-w-container-max mx-auto">
            <a class="text-headline-md font-headline-md font-bold text-primary flex items-center gap-2" asp-page="/Index">
                <span class="material-symbols-outlined text-[22px]">home</span>
                LuxeStay
            </a>
            <div class="hidden md:flex items-center space-x-stack-lg">
                <a class="text-label-md font-label-md text-primary border-b-2 border-primary pb-1" asp-page="/Index">Explore</a>
                <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-colors" asp-page="/Front/GuestFavorites">Favorites</a>
                <a class="text-label-md font-label-md text-on-surface-variant hover:text-primary transition-colors" asp-page="/Front/SignIn">Sign In</a>
            </div>
        </div>
    </nav>
}
