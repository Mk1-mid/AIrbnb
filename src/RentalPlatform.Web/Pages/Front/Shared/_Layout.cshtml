@{
    var title = ViewData["Title"] as string ?? "LuxeStay";
    var htmlLang = (ViewData["HtmlLang"] as string ?? "en").ToLowerInvariant();
    var htmlClass = (ViewData["HtmlClass"] as string ?? string.Empty).ToLowerInvariant();
    var bodyClass = ViewData["BodyClass"] as string ?? "bg-background text-on-background antialiased min-h-screen flex flex-col";
    var frontNavVariant = (ViewData["FrontNavVariant"] as string ?? string.Empty).ToLowerInvariant();
    var frontActiveNav = (ViewData["FrontActiveNav"] as string ?? string.Empty).ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="@htmlLang" class="@htmlClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400..900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    @RenderSection("Head", required: false)
</head>
<body class="@bodyClass">
    <div class="fixed inset-0 -z-10 pointer-events-none">
        <div class="absolute inset-0 bg-background"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-[#0b1b2b] via-background to-background opacity-80"></div>
        <div class="absolute -top-40 right-0 h-[32rem] w-[32rem] rounded-full bg-primary/5 blur-2xl"></div>
        <div class="absolute bottom-0 left-0 h-[28rem] w-[28rem] rounded-full bg-secondary/5 blur-2xl"></div>
    </div>
    @await Html.PartialAsync("~/Pages/Front/Shared/_FrontNavigation.cshtml")

    <main class="flex-1 relative z-10">
        @RenderBody()
    </main>

    <footer class="relative z-10 mt-auto border-t border-outline-variant/10 bg-surface-container-lowest/80 backdrop-blur-xl">
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-xl flex flex-col gap-lg md:flex-row md:items-center md:justify-between">
            <div>
                <div class="text-headline-md font-headline-md text-on-surface tracking-wide">LuxeStay</div>
                <p class="mt-2 text-body-sm font-body-sm text-on-surface-variant max-w-md">Atmósfera editorial, hospitalidad de alto nivel y una experiencia de reserva coherente en todo el front.</p>
            </div>
            <div class="flex flex-wrap items-center gap-md text-label-sm font-label-sm uppercase tracking-widest">
                <a class="text-on-surface-variant hover:text-primary transition-all duration-300" asp-page="/Front/Index">Discover</a>
                <a class="text-on-surface-variant hover:text-primary transition-all duration-300" asp-page="/Front/GuestReservations">Reservations</a>
                <a class="text-on-surface-variant hover:text-primary transition-all duration-300" asp-page="/Front/OwnerDashboard">Dashboard</a>
                <a class="text-on-surface-variant hover:text-primary transition-all duration-300" asp-page="/Privacy">Privacy</a>
            </div>
        </div>
        <div class="border-t border-outline-variant/10">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-md text-label-sm font-label-sm text-on-surface-variant flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                <span>© 2026 LuxeStay. All rights reserved.</span>
                <span class="uppercase tracking-widest">Nocturne Elite system</span>
            </div>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
