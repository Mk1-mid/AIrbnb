@{
    var title = ViewData["Title"] as string ?? "LuxeStay";
    var htmlLang = (ViewData["HtmlLang"] as string ?? "en").ToLowerInvariant();
    var htmlClass = (ViewData["HtmlClass"] as string ?? string.Empty).ToLowerInvariant();
    var bodyClass = ViewData["BodyClass"] as string ?? "bg-background text-on-background antialiased min-h-screen flex flex-col md:flex-row";
    var frontNavVariant = (ViewData["FrontNavVariant"] as string ?? string.Empty).ToLowerInvariant();
    var frontActiveNav = (ViewData["FrontActiveNav"] as string ?? string.Empty).ToLowerInvariant();
}
<!DOCTYPE html>
<html lang="@htmlLang" class="@htmlClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400..900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    @RenderSection("Head", required: false)
</head>
<body class="@bodyClass">
    @if (frontNavVariant == "auth")
    {
        <header class="md:hidden w-full top-0 sticky bg-surface-container-lowest border-b border-outline-variant shadow-sm transition-all duration-200 ease-in-out z-50">
            <div class="flex justify-between items-center w-full px-margin-mobile py-stack-md max-w-container-max mx-auto">
                <div class="text-headline-md font-headline-md font-bold text-primary">LuxeStay</div>
                <div class="flex items-center gap-stack-sm">
                    <button class="text-on-surface-variant hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <div class="w-8 h-8 rounded-full overflow-hidden bg-surface-variant border border-outline-variant">
                        <img alt="Guest profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfvB3EbEuF0zgkA53vBmMN_MJ_8wuIIouCHSq0eT9IDGClqHFWFuu_TmjlM1GSD-Z9zem5nhdgIuxb-YveIuvKxuYmLS6qsBcbHc7X4Qz8vn8wpaoFYjQFYoqSYopMkUCVLKZQk5HwCe1GFzSqgylL5tL1FVnda3Jxz3cCT_fA3JTFHIfTwHIMs-Msz-ss2I9sGg8lAVKWbo4yWT6d4shdxerq8Yj2HWRCIzqCCjLN3YC5d20QDG_S34YLKE6_VCJBOF9t1Ym_h-w" />
                    </div>
                </div>
            </div>
        </header>
    }
    else if (frontNavVariant == "guest" || frontNavVariant == "owner")
    {
        @await Html.PartialAsync("~/Pages/Front/Shared/_FrontNavigation.cshtml")
    }
    else
    {
        @await Html.PartialAsync("~/Pages/Front/Shared/_FrontNavigation.cshtml")
    }

    <main class="flex-1">
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>
