@page
@model RentalPlatform.Web.Pages.Front.OwnerDashboardModel
@{
    ViewData["Title"] = "Dashboard - LuxeStay";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "dark";
    ViewData["BodyClass"] = "bg-background text-on-background min-h-screen flex antialiased";
    ViewData["FrontNavVariant"] = "owner";
    ViewData["FrontActiveNav"] = "dashboard";
}

@section Head {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
        body { font-family: 'DM Sans', sans-serif; }
        h1, h2, h3, h4, h5, h6, .font-display, .font-headline, .font-label { font-family: 'Playfair Display', serif; }
        
        .glass-panel {
            background: rgba(11, 27, 43, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-top: 1px solid rgba(242, 202, 80, 0.2);
            border-left: 1px solid rgba(242, 202, 80, 0.05);
        }
        
        .ambient-shadow-lvl1 {
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        }
    </style>
}

<!-- Main Content Area -->
<main class="flex-1 md:ml-64 p-margin-mobile md:p-margin-desktop max-w-[1600px] w-full mx-auto flex flex-col gap-stack-lg min-h-screen">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row justify-between items-start md:items-end gap-stack-md">
        <div>
            <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary">Dashboard de Rendimiento</h1>
            <p class="text-body-md font-body-md text-on-surface-variant mt-1">Overview of your properties' performance.</p>
        </div>
        <!-- Filters & Actions -->
        <div class="flex flex-wrap items-center gap-stack-sm w-full md:w-auto">
            <div class="relative min-w-[200px] flex-1 md:flex-none">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">home_work</span>
                <select class="w-full pl-10 pr-8 py-2 bg-surface-container-lowest border border-outline-variant rounded-lg text-label-md font-label-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary appearance-none cursor-pointer">
                    <option>All Properties</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px] pointer-events-none">arrow_drop_down</span>
            </div>
            <div class="flex bg-surface-container-low rounded-lg p-1 border border-outline-variant/50">
                <button class="px-4 py-1.5 rounded-md text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-colors">Week</button>
                <button class="px-4 py-1.5 rounded-md text-label-sm font-label-sm bg-surface-container-lowest text-primary shadow-sm ambient-shadow-lvl1">Month</button>
                <button class="px-4 py-1.5 rounded-md text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-colors">Year</button>
            </div>
        </div>
    </header>
    <!-- Metrics Bento Grid -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <div class="glass-panel rounded-xl p-stack-md ambient-shadow-lvl1 flex flex-col justify-between group hover:border-outline transition-colors duration-200">
            <div class="flex justify-between items-start mb-stack-md">
                <div>
                    <p class="text-label-md font-label-md text-on-surface-variant">Total Income</p>
                    <h3 class="text-headline-md font-headline-md text-primary mt-1">$42,850</h3>
                </div>
                <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary group-hover:bg-primary-fixed transition-colors">
                    <span class="material-symbols-outlined text-[20px]">payments</span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="flex items-center text-label-sm font-label-sm text-[#008000] bg-[#e6f4e6] px-2 py-0.5 rounded">
                    <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span> +12.5%
                </span>
                <span class="text-label-sm font-label-sm text-outline">vs last month</span>
            </div>
        </div>
        <div class="glass-panel rounded-xl p-stack-md ambient-shadow-lvl1 flex flex-col justify-between group hover:border-outline transition-colors duration-200">
            <div class="flex justify-between items-start mb-stack-md">
                <div>
                    <p class="text-label-md font-label-md text-on-surface-variant">Total Bookings</p>
                    <h3 class="text-headline-md font-headline-md text-primary mt-1">124</h3>
                </div>
                <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary group-hover:bg-primary-fixed transition-colors">
                    <span class="material-symbols-outlined text-[20px]">book_online</span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="flex items-center text-label-sm font-label-sm text-[#008000] bg-[#e6f4e6] px-2 py-0.5 rounded">
                    <span class="material-symbols-outlined text-[14px] mr-1">trending_up</span> +5.2%
                </span>
                <span class="text-label-sm font-label-sm text-outline">vs last month</span>
            </div>
        </div>
        <div class="glass-panel rounded-xl p-stack-md ambient-shadow-lvl1 flex flex-col justify-between group hover:border-outline transition-colors duration-200">
            <div class="flex justify-between items-start mb-stack-md">
                <div>
                    <p class="text-label-md font-label-md text-on-surface-variant">Occupancy Rate</p>
                    <h3 class="text-headline-md font-headline-md text-primary mt-1">78.4%</h3>
                </div>
                <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary group-hover:bg-primary-fixed transition-colors">
                    <span class="material-symbols-outlined text-[20px]">hotel</span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="flex items-center text-label-sm font-label-sm text-[#ba1a1a] bg-error-container px-2 py-0.5 rounded">
                    <span class="material-symbols-outlined text-[14px] mr-1">trending_down</span> -2.1%
                </span>
                <span class="text-label-sm font-label-sm text-outline">vs last month</span>
            </div>
        </div>
    </section>
    <!-- Charts & Data Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter flex-1">
        <!-- Income Chart -->
        <section class="lg:col-span-2 glass-panel rounded-xl p-stack-md ambient-shadow-lvl1 flex flex-col">
            <div class="flex justify-between items-center mb-stack-md">
                <h2 class="text-body-lg font-body-lg font-semibold text-primary">Income Overview</h2>
                <button class="p-2 text-on-surface-variant hover:text-primary transition-colors rounded-full hover:bg-surface-container-low">
                    <span class="material-symbols-outlined text-[20px]">more_vert</span>
                </button>
            </div>
            <div class="flex-1 w-full relative min-h-[300px]">
                <canvas id="incomeChart"></canvas>
            </div>
        </section>
        <!-- Recent Bookings Table -->
        <section class="glass-panel rounded-xl p-0 ambient-shadow-lvl1 flex flex-col overflow-hidden">
            <div class="p-stack-md border-b border-outline-variant/30 flex justify-between items-center">
                <h2 class="text-body-lg font-body-lg font-semibold text-primary">Recent Bookings</h2>
                <a class="text-label-sm font-label-sm text-secondary hover:text-primary transition-colors underline" href="#">View All</a>
            </div>
            <div class="overflow-y-auto flex-1 max-h-[400px]">
                <table class="w-full text-left border-collapse">
                    <tbody>
                        <tr class="border-b border-outline-variant/20 hover:bg-surface-container-lowest transition-colors">
                            <td class="p-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-primary font-bold text-label-sm">JS</div>
                                    <div>
                                        <p class="text-label-md font-label-md text-primary">John Smith</p>
                                        <p class="text-label-sm font-label-sm text-on-surface-variant">Villa Aurelia</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-4 text-right">
                                <p class="text-label-md font-label-md text-primary">$1,200</p>
                                <p class="text-label-sm font-label-sm text-outline">Oct 12 - 15</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</main>
<!-- Chart.js Initialization -->
<script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('incomeChart').getContext('2d');
            const primaryColor = '#f2ca50';
            ctx.fillStyle = primaryColor;
        });
    </script>
