@page
@model RentalPlatform.Web.Pages.Front.IdentityVerificationModel
@using RentalPlatform.Domain.Enums
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "RentalPlatform - Identity Verification";
    ViewData["HtmlLang"] = "en";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md min-h-screen flex flex-col md:flex-row";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "verification";
}

<main class="flex-1 flex flex-col items-center p-margin-mobile md:p-margin-desktop w-full max-w-container-max mx-auto">
    <div class="w-full max-w-2xl mb-stack-lg text-center">
        <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary mb-stack-sm">Identity Verification</h1>
        <p class="text-body-md font-body-md text-on-surface-variant">Upload a government-issued ID so we can verify your identity before booking.</p>
    </div>

    <div class="w-full max-w-2xl mb-stack-lg rounded-xl border border-outline-variant bg-surface-container-lowest p-stack-md shadow-[0_1px_3px_rgba(15,23,42,0.05)]">
        <h2 class="text-headline-md font-headline-md text-on-surface">Status: 
            <span class="@(Model.Status == KycStatus.Approved ? "text-[#10b981]" : Model.Status == KycStatus.Rejected ? "text-error" : "text-secondary")">
                @(Model.Status?.ToString() ?? "Pending")
            </span>
        </h2>
        <p class="mt-1 text-body-sm font-body-sm text-on-surface-variant">@Model.Message</p>
    </div>

    <form class="w-full max-w-2xl bg-surface-container-lowest border border-outline-variant rounded-xl p-stack-lg shadow-[0_1px_3px_rgba(15,23,42,0.05)] flex flex-col gap-stack-lg" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-error text-body-sm"></div>

        <div class="flex flex-col gap-stack-sm">
            <label class="text-label-md font-label-md text-on-surface" for="UserId">User Id</label>
            <input asp-for="UserId" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 text-body-md font-body-md text-on-surface" placeholder="00000000-0000-0000-0000-000000000000" />
        </div>

        <div class="flex flex-col gap-stack-sm">
            <label class="text-label-md font-label-md text-on-surface" for="Document">Upload Document</label>
            <input asp-for="Document" type="file" accept="image/png, image/jpeg, application/pdf" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 text-body-md font-body-md text-on-surface" />
        </div>

        <div class="flex justify-end pt-stack-md border-t border-outline-variant mt-stack-sm">
            <button class="px-6 py-3 rounded-lg bg-primary text-on-primary text-label-md font-label-md hover:bg-inverse-surface transition-colors" type="submit">
                Submit Verification
            </button>
        </div>
    </form>
</main>
