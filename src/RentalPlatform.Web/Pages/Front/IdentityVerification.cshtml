<script>
        // Simple script to handle file input click area
        document.querySelectorAll('input[type="file"]').forEach(input => {
            const dropzone = input.parentElement;
            dropzone.addEventListener('click', () => input.click());
            
            // Highlight on drag over
            dropzone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropzone.classList.add('border-primary', 'bg-surface-container-low');
            });
            
            dropzone.addEventListener('dragleave', () => {
                dropzone.classList.remove('border-primary', 'bg-surface-container-low');
            });
            
            dropzone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropzone.classList.remove('border-primary', 'bg-surface-container-low');
                if (e.dataTransfer.files.length) {
                    input.files = e.dataTransfer.files;
                    updateUI(dropzone, e.dataTransfer.files[0].name);
                }
            });

            input.addEventListener('change', () => {
                if (input.files.length) {
                    updateUI(dropzone, input.files[0].name);
                }
            });
        });

        function updateUI(dropzone, filename) {
            const textElement = dropzone.querySelector('p.text-on-surface');
            const icon = dropzone.querySelector('.material-symbols-outlined');
            if(textElement && icon) {
                textElement.textContent = filename;
                textElement.classList.add('text-primary', 'font-bold');
                icon.textContent = 'check_circle';
                icon.classList.replace('text-outline', 'text-[#10b981]');
                icon.style.fontVariationSettings = "'FILL' 1";
            }
        }
    </script>

