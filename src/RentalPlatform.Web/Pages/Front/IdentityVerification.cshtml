@page
@model RentalPlatform.Web.Pages.Front.IdentityVerificationModel
@using RentalPlatform.Domain.Enums
@{
    ViewData["Title"] = "Identity Verification - LuxeStay";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "dark";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md antialiased overflow-x-hidden min-h-screen flex flex-col";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "verification";
}

<main class="relative flex-1">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-[#0B1B2B] via-background to-background"></div>
    <div class="absolute top-0 right-0 -z-10 h-80 w-80 rounded-full bg-primary/5 blur-2xl"></div>

    <div class="flex flex-col items-center p-margin-mobile md:p-margin-desktop w-full max-w-container-max mx-auto">
        <div class="w-full max-w-2xl mb-stack-lg text-center">
            <span class="text-label-sm font-label-sm uppercase tracking-widest text-primary">Guest Suite</span>
            <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-on-surface mb-stack-sm">Verificación de identidad</h1>
            <p class="text-body-md font-body-md text-on-surface-variant">Sube un documento oficial para validar tu perfil antes de reservar.</p>
        </div>

        <div class="w-full max-w-2xl mb-stack-lg rounded-lg border border-outline-variant/20 bg-surface-container-lowest/80 p-stack-md shadow-[0_0_30px_rgba(0,0,0,0.35)]">
            <h2 class="text-headline-md font-headline-md text-on-surface">
                Status:
                <span class="@(Model.Status == KycStatus.Approved ? "text-[#10b981]" : Model.Status == KycStatus.Rejected ? "text-error" : "text-secondary")">
                    @(Model.Status?.ToString() ?? "Pending")
                </span>
            </h2>
            <p class="mt-1 text-body-sm font-body-sm text-on-surface-variant">@Model.Message</p>
        </div>

        <form class="w-full max-w-2xl glass-panel border border-primary/20 rounded-lg p-stack-lg shadow-[0_0_30px_rgba(0,0,0,0.35)] flex flex-col gap-stack-lg" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-error text-body-sm"></div>

            <div class="flex flex-col gap-stack-sm">
                <label class="text-label-md font-label-md text-on-surface" for="Document">Upload Document</label>
                <input asp-for="Document" type="file" accept="image/png, image/jpeg, application/pdf" class="w-full bg-surface-container-lowest border border-outline-variant/40 rounded-lg px-4 py-3 text-body-md font-body-md text-on-surface focus:outline-none focus:ring-1 focus:ring-amber-500/50 focus:border-primary transition-all duration-300" />
            </div>

            <div class="flex justify-end pt-stack-md border-t border-outline-variant/20 mt-stack-sm">
                <button class="px-6 py-3 rounded-lg bg-primary text-on-primary text-label-md font-label-md hover:bg-primary-container hover:opacity-95 hover:shadow-[0_0_14px_rgba(242,202,80,0.18)] transition-all duration-300 shadow-[0_0_15px_rgba(242,202,80,0.3)]" type="submit">
                    Enviar verificación
                </button>
            </div>
        </form>
    </div>
</main>
