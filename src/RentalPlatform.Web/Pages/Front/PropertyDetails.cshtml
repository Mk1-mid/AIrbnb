@page "{id:guid}"
@model RentalPlatform.Web.Pages.Front.PropertyDetailsModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = Model.Property?.Title ?? "Property Details";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "light";
    ViewData["BodyClass"] = "bg-surface-container-lowest text-on-surface antialiased min-h-screen flex flex-col";
    ViewData["FrontNavVariant"] = "public";
}

@section Head {
<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>
}

@if (Model.Property == null)
{
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
        <p class="text-body-lg text-on-surface-variant">Property not found.</p>
    </div>
    return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-stack-lg">
        <div class="rounded-lg border border-error/30 bg-error-container p-stack-md text-body-md text-error">@Model.ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-stack-lg">
        <div class="rounded-lg border border-tertiary/30 bg-tertiary-container p-stack-md text-body-md text-tertiary">@Model.SuccessMessage</div>
    </div>
}

<section class="w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 flex flex-col">
        <div class="relative w-full h-80 overflow-hidden">
            <div class="w-full h-full bg-cover bg-center" style="background-image: url('https://picsum.photos/seed/@Model.Property.Id/1200/600')"></div>
        </div>
        <div class="p-stack-md flex flex-col flex-1">
            <div class="flex justify-between items-start mb-1">
                <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary">@Model.Property.Title</h1>
                <div class="flex items-center gap-1 text-label-sm font-label-sm">
                    <span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                    <span>4.9</span>
                </div>
            </div>
            <p class="text-body-md font-body-md text-on-surface-variant mb-4 flex items-center gap-1">
                <span class="material-symbols-outlined text-[18px]">location_on</span>
                @Model.Property.City
            </p>
            <p class="text-body-md font-body-md text-on-surface mb-6">@Model.Property.Description</p>
            
            <form method="post" class="mt-auto pt-stack-sm border-t border-surface-container-highest">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-md items-end">
                    <div>
                        <label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="CheckIn">Check-in</label>
                        <input asp-for="CheckIn" class="w-full px-3 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" type="date"/>
                    </div>
                    <div>
                        <label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="CheckOut">Check-out</label>
                        <input asp-for="CheckOut" class="w-full px-3 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" type="date"/>
                    </div>
                    <div>
                        <button class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-label-md font-label-md text-on-primary bg-primary hover:bg-inverse-surface focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" type="submit">
                            Reserve - $@((Model.Property.PricePerNight.Amount).ToString("N0")) / night
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </article>
</section>