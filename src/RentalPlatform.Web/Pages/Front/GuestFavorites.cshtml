<!-- Empty State (Hidden by default, shown when no favorites) -->
<div class="hidden flex-col items-center justify-center py-stack-lg mt-stack-lg border border-dashed border-outline-variant rounded-xl bg-surface-container-lowest">
<span class="material-symbols-outlined text-[48px] text-outline-variant mb-4" data-icon="heart_plus">heart_plus</span>
<h3 class="text-headline-md font-headline-md text-on-background mb-2">No favorites yet</h3>
<p class="text-body-md font-body-md text-on-surface-variant mb-6 text-center max-w-md">Start saving properties you love to build your collection of potential stays.</p>
<button class="px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-background hover:border-primary hover:text-primary transition-colors flex items-center gap-2">
                Explore Properties
            </button>
</div>
