</div>
</div>
<div class="p-6 flex flex-col flex-grow">
<div class="flex justify-between items-start mb-2">
<h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">Skyline Penthouse</h2>
<div class="flex items-center gap-1 text-on-background">
<span class="material-symbols-outlined text-[16px]" data-icon="star" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="text-label-md font-label-md font-bold">4.8</span>
</div>
</div>
<p class="text-body-sm font-body-sm text-on-surface-variant mb-4">New York City, NY</p>
