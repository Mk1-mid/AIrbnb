<div class="flex items-center gap-1 text-on-background">
<span class="material-symbols-outlined text-[16px]" data-icon="star" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="text-label-md font-label-md font-bold">5.0</span>
</div>
</div>
<p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Scottsdale, Arizona</p>
<div class="flex flex-wrap gap-2 mb-6">
