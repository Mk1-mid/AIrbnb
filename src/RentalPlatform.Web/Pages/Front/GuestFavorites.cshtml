<!-- Footer -->
<footer class="w-full bg-surface-container-lowest border-t border-outline-variant z-10 md:ml-64">
<div class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-stack-lg max-w-container-max mx-auto gap-4">
<div class="text-label-md font-label-md font-bold text-primary">LuxeStay</div>
<div class="flex flex-wrap gap-4 justify-center">
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Terms</a>
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Privacy</a>
