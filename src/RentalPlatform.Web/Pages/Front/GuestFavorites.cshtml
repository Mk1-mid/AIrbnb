@page
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Mis Favoritos";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md min-h-screen flex flex-col md:flex-row";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "favorites";
}

@section Head {
<style>
        .card-shadow { box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05); }
        .card-shadow-hover { box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08); }
    </style>
}

<!-- SideNavBar (Desktop Only) -->
<nav class="hidden md:flex flex-col h-screen w-64 fixed left-0 top-0 bg-surface-container-low p-stack-md gap-stack-sm z-40 border-r border-outline-variant">
<div class="mb-stack-lg flex items-center gap-stack-sm px-4">
<span class="material-symbols-outlined text-headline-md font-headline-md font-bold text-primary" data-icon="home_work">home_work</span>
<span class="text-headline-md font-headline-md font-bold text-primary">LuxeStay</span>
</div>
<div class="flex flex-col gap-2 flex-grow">
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
                Dashboard
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="calendar_today">calendar_today</span>
                My Bookings
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="explore">explore</span>
                Explore
            </a>
<a class="flex items-center gap-3 px-4 py-2 bg-secondary-container text-on-secondary-container rounded-lg font-bold transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="favorite" style="font-variation-settings: 'FILL' 1;">favorite</span>
                Favorites
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
                Settings
            </a>
</div>
<div class="mt-auto flex flex-col gap-2 border-t border-outline-variant pt-stack-md">
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="help">help</span>
                Help Center
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-transform duration-150 text-label-md font-label-md" href="#">
<span class="material-symbols-outlined" data-icon="logout">logout</span>
                Logout
            </a>
<div class="flex items-center gap-3 px-4 py-2 mt-2">
<img alt="Guest profile" class="w-10 h-10 rounded-full object-cover border border-outline-variant" data-alt="A highly detailed, professional headshot portrait of a confident property manager in modern corporate attire. They are smiling subtly against a crisp, high-key bright white background. The lighting is soft and flattering, creating a polished, institutional trust aesthetic suitable for a high-end platform." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfvB3EbEuF0zgkA53vBmMN_MJ_8wuIIouCHSq0eT9IDGClqHFWFuu_TmjlM1GSD-Z9zem5nhdgIuxb-YveIuvKxuYmLS6qsBcbHc7X4Qz8vn8wpaoFYjQFYoqSYopMkUCVLKZQk5HwCe1GFzSqgylL5tL1FVnda3Jxz3cCT_fA3JTFHIfTwHIMs-Msz-ss2I9sGg8lAVKWbo4yWT6d4shdxerq8Yj2HWRCIzqCCjLN3YC5d20QDG_S34YLKE6_VCJBOF9t1Ym_h-w"/>
<div>
<div class="text-label-md font-label-md font-bold text-on-background">Guest Account</div>
<div class="text-body-sm font-body-sm text-on-surface-variant">Verified</div>
</div>
</div>
</div>
</nav>
<!-- Main Content Canvas -->
<main class="flex-grow md:ml-64 w-full px-margin-mobile md:px-margin-desktop py-stack-lg max-w-container-max mx-auto">
<header class="mb-stack-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-stack-md">
<div>
<h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg font-bold text-on-background mb-2">Mis Favoritos</h1>
<p class="text-body-md font-body-md text-on-surface-variant">Your curated collection of premium short-term rentals.</p>
</div>
<div class="flex gap-2">
<button class="px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface-variant hover:border-primary hover:text-primary transition-colors flex items-center gap-2 bg-surface-container-lowest">
<span class="material-symbols-outlined text-[18px]" data-icon="filter_list">filter_list</span>
                    Filter
                </button>
</div>
</header>
<!-- Bento Grid of Favorites -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
<!-- Property Card 1 -->
<article class="bg-surface-container-lowest border border-outline-variant rounded-xl card-shadow hover:card-shadow-hover hover:border-[#CBD5E1] transition-all duration-200 overflow-hidden group flex flex-col h-full">
<div class="relative w-full h-48 md:h-56 bg-surface-variant overflow-hidden">
<img alt="Villa Luna" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="A stunning, high-resolution architectural photograph of a modern luxury villa exterior with expansive glass windows and a sleek minimalist pool. The scene is bathed in bright, clear daylight under a cloudless sky, emphasizing the clean lines and professional high-end real estate aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAJMvHCuY-qRCYT7PBqPcgrB5Ns0tzQUog7XLUsPGrmuz1Nj3juoEyCyosDv-4gJw2C55A8QUbai6-lCY4x7cmXP5hkwF5eIm14uWCVLzxmixFS4IW903iz6bqYmoh8Qel26WweXWkRXGIAxwNNYmjgevQM4WDRbRvLhlHqlhR-qovytPRwCEGQOMhRh4mxTrAFmP4HrnxOQVvsJi_Y_bkfkwJMuQkBODf4IcnHN6NxQxdwgqPM_DA-VnHubD0ilW80SkzMpYHXuLY"/>
<button aria-label="Remove from favorites" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm flex items-center justify-center text-primary hover:bg-surface-container-lowest transition-colors border border-outline-variant/50 shadow-sm">
<span class="material-symbols-outlined text-[20px]" data-icon="heart_broken">heart_broken</span>
</button>
<div class="absolute bottom-4 left-4 flex gap-2">
<span class="bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-on-surface shadow-sm">Villa</span>
</div>
</div>
<div class="p-6 flex flex-col flex-grow">
<div class="flex justify-between items-start mb-2">
<h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">Villa Luna</h2>
<div class="flex items-center gap-1 text-on-background">
<span class="material-symbols-outlined text-[16px]" data-icon="star" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="text-label-md font-label-md font-bold">4.9</span>
</div>
</div>
<p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Los Angeles, California</p>
<div class="flex flex-wrap gap-2 mb-6">
<span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">4 Beds</span>
<span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">3 Baths</span>
<span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">Pool</span>
</div>
<div class="mt-auto flex justify-between items-center pt-4 border-t border-[#F1F5F9]">
<div>
<span class="text-headline-md font-headline-md text-on-background font-bold">$850</span>
<span class="text-body-sm font-body-sm text-on-surface-variant">/night</span>
</div>
<button class="bg-primary text-on-primary px-4 py-2 rounded-lg text-label-md font-label-md hover:bg-primary/90 transition-colors">
