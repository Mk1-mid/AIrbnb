@page
@model RentalPlatform.Web.Pages.Front.GuestFavoritesModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Mis Favoritos";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md min-h-screen flex flex-col md:flex-row";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "favorites";
}

@section Head {
<style>
        .card-shadow { box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05); }
        .card-shadow-hover { box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08); }
    </style>
}

<!-- Main Content Canvas -->
<main class="flex-grow md:ml-64 w-full px-margin-mobile md:px-margin-desktop py-stack-lg max-w-container-max mx-auto">
    <header class="mb-stack-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-stack-md">
        <div>
            <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg font-bold text-on-background mb-2">Mis Favoritos</h1>
            @if (!Model.Favorites.Any())
            {
                <p class="text-body-md font-body-md text-on-surface-variant">Sign in to save and view your favorite properties.</p>
            }
            else
            {
                <p class="text-body-md font-body-md text-on-surface-variant">Your curated collection of <span class="font-bold text-primary">@Model.Favorites.Count()</span> saved properties.</p>
            }
        </div>
    </header>

    @if (!Model.Favorites.Any())
    {
        <!-- Placeholder Favorites -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
            <article class="bg-surface-container-lowest border border-outline-variant rounded-xl card-shadow hover:card-shadow-hover hover:border-[#CBD5E1] transition-all duration-200 overflow-hidden group flex flex-col h-full">
                <a asp-page="/Front/SignIn" class="block">
                    <div class="relative w-full h-48 md:h-56 bg-surface-variant overflow-hidden">
                        <img alt="Villa Luna" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAJMvHCuY-qRCYT7PBqPcgrB5Ns0tzQUog7XLUsPGrmuz1Nj3juoEyCyosDv-4gJw2C55A8QUbai6-lCY4x7cmXP5hkwF5eIm14uWCVLzxmixFS4IW903iz6bqYmoh8Qel26WweXWkRXGIAxwNNYmjgevQM4WDRbRvLhlHqlhR-qovytPRwCEGQOMhRh4mxTrAFmP4HrnxOQVvsJi_Y_bkfkwJMuQkBODf4IcnHN6NxQxdwgqPM_DA-VnHubD0ilW80SkzMpYHXuLY"/>
                        <div class="absolute bottom-4 left-4 flex gap-2">
                            <span class="bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-on-surface shadow-sm">Villa</span>
                        </div>
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">Villa Luna</h2>
                            <div class="flex items-center gap-1 text-on-background">
                                <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="text-label-md font-label-md font-bold">4.9</span>
                            </div>
                        </div>
                        <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Los Angeles, California</p>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">Pool</span>
                        </div>
                        <div class="mt-auto flex justify-between items-center pt-4 border-t border-[#F1F5F9]">
                            <div>
                                <span class="text-headline-md font-headline-md text-on-background font-bold">$850</span>
                                <span class="text-body-sm font-body-sm text-on-surface-variant">/night</span>
                            </div>
                        </div>
                    </div>
                </a>
            </article>
            
            <article class="bg-surface-container-lowest border border-outline-variant rounded-xl card-shadow hover:card-shadow-hover hover:border-[#CBD5E1] transition-all duration-200 overflow-hidden group flex flex-col h-full">
                <a asp-page="/Front/SignIn" class="block">
                    <div class="relative w-full h-48 md:h-56 bg-surface-variant overflow-hidden">
                        <img alt="Skyline Penthouse" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0XirMwYQBJ2aRIW8b_sTFRkXjQpjR_E2DRAebFZhTShMSk2R_QYbuEqcPqW6_x7C6cZ6TUDIQoInk1Trw9a_M-2Sf4zIyIZoeDzVT7UMis4xGMJk0093zDs9EvrLLWdyRugKh-Lo_mw7X9OHWT7uPqARRTNO_VTAowlXRvaD6bEdXIKRspKCMAXtf5BhSt15v8k_OT2xmTVDQ0yMM2UqMZDOptATVdVxHdYdwZodf2QZd9YB13amomixo8iiaobepdTBqea51G6Q"/>
                        <div class="absolute bottom-4 left-4 flex gap-2">
                            <span class="bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-on-surface shadow-sm">Penthouse</span>
                        </div>
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">Skyline Penthouse</h2>
                            <div class="flex items-center gap-1 text-on-background">
                                <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="text-label-md font-label-md font-bold">4.8</span>
                            </div>
                        </div>
                        <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">New York City, NY</p>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">City View</span>
                        </div>
                        <div class="mt-auto flex justify-between items-center pt-4 border-t border-[#F1F5F9]">
                            <div>
                                <span class="text-headline-md font-headline-md text-on-background font-bold">$1,200</span>
                                <span class="text-body-sm font-body-sm text-on-surface-variant">/night</span>
                            </div>
                        </div>
                    </div>
                </a>
            </article>

            <article class="bg-surface-container-lowest border border-outline-variant rounded-xl card-shadow hover:card-shadow-hover hover:border-[#CBD5E1] transition-all duration-200 overflow-hidden group flex flex-col h-full">
                <a asp-page="/Front/SignIn" class="block">
                    <div class="relative w-full h-48 md:h-56 bg-surface-variant overflow-hidden">
                        <img alt="Desert Modern" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCm4s3hn7iZsz1eg0aG781FSte26ZRM_eAPen49FSzS96mTgyuiaEJykMl5FcecudyHgIVBWE_rLR2U7sd6f0Sf9PB0PVK24_VvYVsXB8aDR5x_c7loTbmA9jJWRqbvxu-zbwIfQFMWhHZJ9jqATCmBKwPhyrqTp4a0EF_I_H5Sshrf1fYkd1NgFTn24NkJ-IyUZybtEHc2N-O_oSIQeVDakp_20BfWRtHvqSVJcoS8bbIIik2ACExNm3FMSr6eHzk3F4KLXuCV0mg"/>
                        <div class="absolute bottom-4 left-4 flex gap-2">
                            <span class="bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-on-surface shadow-sm">Retreat</span>
                        </div>
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">Desert Modern</h2>
                            <div class="flex items-center gap-1 text-on-background">
                                <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                <span class="text-label-md font-label-md font-bold">5.0</span>
                            </div>
                        </div>
                        <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Scottsdale, Arizona</p>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant border border-[#F1F5F9]">Firepit</span>
                        </div>
                        <div class="mt-auto flex justify-between items-center pt-4 border-t border-[#F1F5F9]">
                            <div>
                                <span class="text-headline-md font-headline-md text-on-background font-bold">$650</span>
                                <span class="text-body-sm font-body-sm text-on-surface-variant">/night</span>
                            </div>
                        </div>
                    </div>
                </a>
            </article>
        </div>
        <div class="text-center mt-8">
            <a asp-page="/Front/Register" class="inline-flex items-center px-6 py-3 bg-primary text-on-primary rounded-lg text-label-md font-label-md hover:bg-primary/90 transition-colors font-medium">
                <span class="material-symbols-outlined mr-2">person_add</span>
                Sign up to save your favorites
            </a>
        </div>
    }
    else
    {
        <!-- Real Data Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
            @foreach (var property in Model.Favorites)
            {
                <article class="bg-surface-container-lowest border border-outline-variant rounded-xl card-shadow hover:card-shadow-hover hover:border-[#CBD5E1] transition-all duration-200 overflow-hidden group flex flex-col h-full">
                    <a asp-page="/Front/PropertyDetails" asp-route-id="@property.Id" class="block">
                        <div class="relative w-full h-48 md:h-56 bg-surface-variant overflow-hidden">
                            <img alt="@property.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://picsum.photos/seed/@property.Id/600/400"/>
                        </div>
                        <div class="p-6 flex flex-col flex-grow">
                            <div class="flex justify-between items-start mb-2">
                                <h2 class="text-headline-md font-headline-md text-on-background line-clamp-1">@property.Title</h2>
                                <div class="flex items-center gap-1 text-on-background">
                                    <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
                                    <span class="text-label-md font-label-md font-bold">4.9</span>
                                </div>
                            </div>
                            <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">@property.City</p>
                            <div class="mt-auto flex justify-between items-center pt-4 border-t border-[#F1F5F9]">
                                <div>
                                    <span class="text-headline-md font-headline-md text-on-background font-bold">$@property.PricePerNight.Amount.ToString("N0")</span>
                                    <span class="text-body-sm font-body-sm text-on-surface-variant">/night</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </article>
            }
        </div>
    }
</main>