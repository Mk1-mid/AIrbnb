@page
@model RentalPlatform.Web.Pages.Front.OwnerReportsModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Exportar Reporte";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "flex min-h-screen font-body-md";
    ViewData["FrontNavVariant"] = "owner";
    ViewData["FrontActiveNav"] = "reports";
}

@section Head {
<style>
        body {
            background-color: theme('colors.background');
            color: theme('colors.on-background');
        }
        /* Level 1 Shadow */
        .shadow-level-1 {
            box-shadow: 0px 1px 3px rgba(15, 23, 42, 0.05);
        }
        /* Level 2 Shadow */
        .shadow-level-2 {
            box-shadow: 0px 4px 12px rgba(15, 23, 42, 0.08);
        }
        
        .interactive-lift {
            transition: all 0.2s ease-in-out;
        }
        .interactive-lift:hover {
            box-shadow: 0px 4px 12px rgba(15, 23, 42, 0.08);
            border-color: #CBD5E1;
            transform: translateY(-1px);
        }

        .input-focus-ring:focus-within {
            border-color: theme('colors.primary');
            box-shadow: 0 0 0 2px theme('colors.secondary-fixed-dim');
        }
      </style>
}

<!-- Main Content Canvas -->
<main class="flex-1 md:ml-64 p-margin-mobile md:p-margin-desktop min-h-screen">
<!-- Header -->
<header class="mb-stack-lg">
<h1 class="text-headline-lg font-headline-lg md:text-headline-lg md:font-headline-lg text-primary mb-2">Exportar Reporte</h1>
<p class="text-body-lg font-body-lg text-on-surface-variant">Generate and download detailed financial and operational data for your properties.</p>
</header>
<!-- Configuration Card -->
<div class="bg-surface-container-lowest border border-[#E2E8F0] rounded-xl shadow-level-1 p-6 md:p-8 mb-stack-lg max-w-4xl">
<form method="post" asp-page="/Front/OwnerReports" class="space-y-stack-lg">
<!-- Report Type Selection -->
<section>
<h2 class="text-headline-md font-headline-md text-primary mb-stack-md flex items-center gap-2">
<span class="material-symbols-outlined" data-icon="summarize">summarize</span>
                        Report Type
                    </h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-stack-md">
<label class="relative flex flex-col bg-surface border border-[#E2E8F0] rounded-lg p-4 cursor-pointer hover:border-outline-variant transition-colors group">
<input checked="" class="absolute right-4 top-4 text-primary focus:ring-primary" name="reportType" type="radio" value="financial"/>
<span class="material-symbols-outlined text-secondary mb-2" data-icon="account_balance">account_balance</span>
<span class="text-label-md font-label-md text-primary mb-1">Financial Summary</span>
<span class="text-body-sm font-body-sm text-on-surface-variant">Revenue, fees, and net payouts.</span>
</label>
<!-- Option 2 -->
<label class="relative flex flex-col bg-surface border border-[#E2E8F0] rounded-lg p-4 cursor-pointer hover:border-outline-variant transition-colors group">
<input class="absolute right-4 top-4 text-primary focus:ring-primary" name="reportType" type="radio" value="occupancy"/>
<span class="material-symbols-outlined text-secondary mb-2" data-icon="hotel">hotel</span>
<span class="text-label-md font-label-md text-primary mb-1">Occupancy Metrics</span>
<span class="text-body-sm font-body-sm text-on-surface-variant">Booking rates and guest demographics.</span>
</label>
<!-- Option 3 -->
<label class="relative flex flex-col bg-surface border border-[#E2E8F0] rounded-lg p-4 cursor-pointer hover:border-outline-variant transition-colors group">
<input class="absolute right-4 top-4 text-primary focus:ring-primary" name="reportType" type="radio" value="maintenance"/>
<span class="material-symbols-outlined text-secondary mb-2" data-icon="handyman">handyman</span>
<span class="text-label-md font-label-md text-primary mb-1">Maintenance Logs</span>
<span class="text-body-sm font-body-sm text-on-surface-variant">Service requests and resolution times.</span>
</label>
</div>
</section>
<div class="border-t border-[#F1F5F9] w-full"></div>
<!-- Filters: Date Range & Property -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
<!-- Date Range Filter -->
<div class="space-y-stack-sm">
<label class="text-label-md font-label-md text-primary flex items-center gap-2">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="date_range">date_range</span>
                            Date Range
                        </label>
<div class="flex items-center gap-2">
<div class="flex-1 input-focus-ring bg-surface-container-lowest border border-[#E2E8F0] rounded-lg px-3 py-2 flex items-center transition-colors">
<input class="w-full bg-transparent border-none p-0 focus:ring-0 text-body-md font-body-md text-primary" type="date" name="From" value="2023-01-01" required />
</div>
<span class="text-on-surface-variant">to</span>
<div class="flex-1 input-focus-ring bg-surface-container-lowest border border-[#E2E8F0] rounded-lg px-3 py-2 flex items-center transition-colors">
<input class="w-full bg-transparent border-none p-0 focus:ring-0 text-body-md font-body-md text-primary" type="date" name="To" value="2023-12-31" required />
</div>
</div>
</div>
<!-- Property Filter -->
<div class="space-y-stack-sm">
<label class="text-label-md font-label-md text-primary flex items-center gap-2">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="real_estate_agent">real_estate_agent</span>
                            Property Selection
                        </label>
<div class="input-focus-ring bg-surface-container-lowest border border-[#E2E8F0] rounded-lg px-3 py-2 flex items-center transition-colors relative">
<select class="w-full bg-transparent border-none p-0 focus:ring-0 text-body-md font-body-md text-primary appearance-none pr-8" name="PropertyId">
<option value="">All Properties (Portfolio Wide)</option>
<option value="p1">Villa Paradiso - Miami</option>
<option value="p2">The Alpine Loft - Aspen</option>
<option value="p3">Downtown Penthouse - NYC</option>
</select>
<span class="material-symbols-outlined absolute right-3 pointer-events-none text-on-surface-variant" data-icon="expand_more">expand_more</span>
</div>
</div>
</section>
<div class="border-t border-[#F1F5F9] w-full"></div>
<!-- Export Actions -->
<section class="flex flex-col sm:flex-row items-center justify-between gap-stack-md pt-2">
<div class="flex items-center gap-2 text-on-surface-variant text-body-sm font-body-sm">
<span class="material-symbols-outlined text-outline" data-icon="info">info</span>
                        Estimated generation time: ~15 seconds.
                    </div>
<div class="flex gap-4 w-full sm:w-auto">
<!-- Secondary Action -->
<button class="flex-1 sm:flex-none px-6 py-3 border border-[#E2E8F0] text-secondary font-label-md text-label-md rounded-lg hover:bg-surface-container-low transition-colors bg-transparent" type="button">
                            Preview Data
                        </button>
<!-- Primary CTA -->
<button class="flex-1 sm:flex-none px-8 py-3 bg-primary text-on-primary font-label-md text-label-md rounded-lg shadow-sm hover:bg-primary-container transition-colors flex items-center justify-center gap-2 interactive-lift" type="submit">
<span class="material-symbols-outlined" data-icon="download">download</span>
                            Descargar Excel
                        </button>
</div>
</section>
</form>
</div>
<!-- Recent Exports (Bento-style list) -->
<div class="max-w-4xl">
<h3 class="text-headline-md font-headline-md text-primary mb-stack-md">Recent Exports</h3>
<div class="bg-surface-container-lowest border border-[#E2E8F0] rounded-xl overflow-hidden">
<!-- Header row -->
<div class="grid grid-cols-12 gap-4 p-4 border-b border-[#F1F5F9] bg-surface-container-low text-label-sm font-label-sm text-on-surface-variant uppercase tracking-wider">
<div class="col-span-5 md:col-span-4">Report Name</div>
<div class="col-span-4 md:col-span-3">Date Range</div>
<div class="hidden md:block col-span-3">Generated</div>
<div class="col-span-3 md:col-span-2 text-right">Action</div>
</div>
<!-- Item 1 -->
<div class="grid grid-cols-12 gap-4 p-4 border-b border-[#F1F5F9] hover:bg-[#F8FAFC] transition-colors items-center">
<div class="col-span-5 md:col-span-4 flex items-center gap-3">
<span class="material-symbols-outlined text-secondary" data-icon="description">description</span>
<span class="text-body-md font-body-md text-primary font-medium truncate">Q3 Financial Summary</span>
</div>
<div class="col-span-4 md:col-span-3 text-body-sm font-body-sm text-on-surface-variant">Jul 1 - Sep 30, 2023</div>
<div class="hidden md:block col-span-3 text-body-sm font-body-sm text-on-surface-variant">Oct 2, 2023</div>
<div class="col-span-3 md:col-span-2 text-right">
<button class="text-primary hover:text-secondary transition-colors" title="Re-download">
<span class="material-symbols-outlined" data-icon="download">download</span>
</button>
</div>
</div>
<!-- Item 2 -->
<div class="grid grid-cols-12 gap-4 p-4 border-b border-[#F1F5F9] hover:bg-[#F8FAFC] transition-colors items-center">
<div class="col-span-5 md:col-span-4 flex items-center gap-3">
<span class="material-symbols-outlined text-secondary" data-icon="description">description</span>
<span class="text-body-md font-body-md text-primary font-medium truncate">August Occupancy</span>
</div>
<div class="col-span-4 md:col-span-3 text-body-sm font-body-sm text-on-surface-variant">Aug 1 - Aug 31, 2023</div>
<div class="hidden md:block col-span-3 text-body-sm font-body-sm text-on-surface-variant">Sep 1, 2023</div>
<div class="col-span-3 md:col-span-2 text-right">
<button class="text-primary hover:text-secondary transition-colors" title="Re-download">
<span class="material-symbols-outlined" data-icon="download">download</span>
</button>
</div>
</div>
<!-- Item 3 -->
<div class="grid grid-cols-12 gap-4 p-4 hover:bg-[#F8FAFC] transition-colors items-center">
<div class="col-span-5 md:col-span-4 flex items-center gap-3">
<span class="material-symbols-outlined text-secondary" data-icon="description">description</span>
<span class="text-body-md font-body-md text-primary font-medium truncate">YTD Maintenance Log</span>
</div>
<div class="col-span-4 md:col-span-3 text-body-sm font-body-sm text-on-surface-variant">Jan 1 - Sep 30, 2023</div>
<div class="hidden md:block col-span-3 text-body-sm font-body-sm text-on-surface-variant">Oct 1, 2023</div>
<div class="col-span-3 md:col-span-2 text-right">
<button class="text-primary hover:text-secondary transition-colors" title="Re-download">
<span class="material-symbols-outlined" data-icon="download">download</span>
</button>
</div>
</div>
</div>
</div>
</main>
