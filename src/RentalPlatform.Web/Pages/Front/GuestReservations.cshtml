@page
@model RentalPlatform.Web.Pages.Front.GuestReservationsModel
@{
    ViewData["Title"] = "Guest Reservations - LuxeStay";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "dark";
    ViewData["BodyClass"] = "bg-background text-on-background antialiased flex min-h-screen flex-col";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "reservations";
}

@section Head {
<style>
    .glass-panel {
        background-color: rgba(11, 27, 43, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .golden-glow {
        box-shadow: 0 0 20px 0 rgba(242, 202, 80, 0.15);
    }
</style>
}

<main class="relative flex-1 md:ml-64 overflow-y-auto">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-[#0B1B2B] via-background to-background"></div>
    <div class="absolute top-0 right-0 -z-10 h-96 w-96 rounded-full bg-primary/5 blur-2xl"></div>

    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
        <header class="mb-stack-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-stack-md">
            <div>
                <span class="text-label-sm font-label-sm uppercase tracking-widest text-primary">Guest Suite</span>
                <h1 class="text-display-lg font-display-lg text-on-surface">Mis Reservas</h1>
                <p class="text-body-lg font-body-lg text-on-surface-variant">Manage your upcoming and past stays.</p>
            </div>
            <div class="hidden md:flex gap-base bg-surface-container-low p-1 rounded-lg border border-outline-variant/30">
                <button class="px-4 py-1.5 bg-surface-container-lowest text-on-surface rounded-md shadow-sm text-label-md font-label-md font-bold" type="button">Todas</button>
                <button class="px-4 py-1.5 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-lowest/40 rounded-md text-label-md font-label-md transition-all duration-300" type="button">Próximas</button>
                <button class="px-4 py-1.5 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-lowest/40 rounded-md text-label-md font-label-md transition-all duration-300" type="button">Completadas</button>
            </div>
        </header>

        <div class="flex flex-col gap-stack-md">
            @foreach (var reservation in Model.Reservations)
            {
                <article class="glass-panel flex flex-col md:flex-row gap-gutter p-stack-md border border-outline-variant/20 rounded-lg shadow-[0_0_30px_rgba(0,0,0,0.35)] transition-all duration-200 group">
                    <div class="w-full md:w-72 h-48 md:h-auto rounded-lg overflow-hidden shrink-0 border border-outline-variant/20">
                        <img class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" src="@(reservation.Property.Images.FirstOrDefault()?.Url ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuBSJu88aKTbMee8PPT0XU78YPvG7Vci2UFsalZA1MZvYMoU6qbAYOh-Ze6KaLhbyWRnQxWPOZ2KaD0o9DDLurRy8wC6lymqrz4_sdC_FJU_TijY8D71kjdYoMdxR1e3C9b-uoHWeCipggyInntPdpoNaw1jlTOGLrTEw95Vh-uoIt47jwauLopIsFdKB9H5XgykRRfKHP6Fple1XF4jmRfswJHePgpY0gmov0C4qbw1oklZCv5E3kqrgFruFXg0j4a87es_FkwDw6Y")" alt="@reservation.Property.Title" />
                    </div>
                    <div class="flex flex-col justify-between flex-1 py-1">
                        <div>
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="text-headline-md font-headline-md text-on-surface">@reservation.Property.Title</h3>
                                <span class="px-2.5 py-1 rounded-md text-label-sm font-label-sm bg-tertiary-container text-on-tertiary-container border border-tertiary-fixed-dim/30">@reservation.Status</span>
                            </div>
                            <p class="text-body-md font-body-md text-on-surface-variant flex items-center gap-1">
                                <span class="material-symbols-outlined text-[18px] text-primary">location_on</span> @reservation.Property.City
                            </p>
                        </div>
                        <div class="grid grid-cols-2 gap-stack-md mt-stack-md bg-surface-container-low/50 p-4 rounded-lg border border-outline-variant/30">
                            <div>
                                <p class="text-label-sm font-label-sm text-on-secondary-container mb-1">CHECK-IN</p>
                                <p class="text-body-md font-body-md font-medium text-on-surface">@reservation.StayPeriod.CheckIn.ToString("MMM dd, yyyy")</p>
                            </div>
                            <div>
                                <p class="text-label-sm font-label-sm text-on-secondary-container mb-1">CHECK-OUT</p>
                                <p class="text-body-md font-body-md font-medium text-on-surface">@reservation.StayPeriod.CheckOut.ToString("MMM dd, yyyy")</p>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</main>
