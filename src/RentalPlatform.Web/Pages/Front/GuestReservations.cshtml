@page
@model RentalPlatform.Web.Pages.Front.GuestReservationsModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "Mis Reservas - LuxeStay";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "light";
    ViewData["BodyClass"] = "bg-background text-on-background antialiased flex h-screen overflow-hidden";
    ViewData["FrontNavVariant"] = "guest";
    ViewData["FrontActiveNav"] = "reservations";
}

@section Head {
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .icon-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
}

@using RentalPlatform.Domain.Enums

<!-- Main Content Area -->
<main class="flex-1 md:ml-64 overflow-y-auto bg-surface-container-lowest relative">
<div class="max-w-container-max mx-auto px-margin-desktop py-stack-lg">
<!-- Page Header -->
<header class="mb-stack-lg flex justify-between items-end">
<div>
<h1 class="text-display-lg font-display-lg text-primary">Mis Reservas</h1>
<p class="text-body-lg font-body-lg text-on-surface-variant mt-base">Manage your upcoming and past stays.</p>
</div>
<!-- Simple Filter Tabs -->
<div class="hidden md:flex gap-base bg-surface-container-low p-1 rounded-lg border border-outline-variant/30">
<button class="px-4 py-1.5 bg-surface-container-lowest text-on-surface rounded-md shadow-sm text-label-md font-label-md font-bold">Todas</button>
<button class="px-4 py-1.5 text-on-surface-variant hover:text-on-surface rounded-md text-label-md font-label-md transition-colors">Próximas</button>
<button class="px-4 py-1.5 text-on-surface-variant hover:text-on-surface rounded-md text-label-md font-label-md transition-colors">Completadas</button>
</div>
</header>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="mb-stack-md rounded-lg border border-error/30 bg-error-container p-stack-md text-body-md text-error">@Model.ErrorMessage</div>
}

@if (!Model.Reservations.Any())
{
    <div class="text-center py-20">
        <p class="text-body-lg text-on-surface-variant">No reservations yet.</p>
        <a href="/Front/Index" class="text-primary underline mt-4 inline-block">Browse properties</a>
    </div>
}
else
{
    <!-- Bookings List -->
    <div class="flex flex-col gap-stack-md">
        @foreach (var reservation in Model.Reservations)
        {
            var statusClass = reservation.Status switch
            {
                ReservationStatus.Confirmed => "bg-tertiary-container text-on-tertiary-container border-tertiary-fixed-dim/30",
                ReservationStatus.Pending => "bg-surface-variant text-on-surface border-outline-variant/50",
                ReservationStatus.Completed => "bg-secondary-container text-on-secondary-container border-secondary-fixed-dim/30",
                ReservationStatus.Cancelled => "bg-error-container text-on-error-container border-error/20",
                _ => "bg-surface-variant text-on-surface border-outline-variant/50"
            };

            var statusText = reservation.Status switch
            {
                ReservationStatus.Confirmed => "Confirmada",
                ReservationStatus.Pending => "Pendiente",
                ReservationStatus.Completed => "Completada",
                ReservationStatus.Cancelled => "Cancelada",
                _ => reservation.Status.ToString()
            };
            
            <article class="flex flex-col md:flex-row gap-gutter p-stack-md bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm hover:shadow-[0_4px_12px_rgba(15,23,42,0.08)] transition-all duration-200 group">
                <div class="w-full md:w-72 h-48 md:h-auto rounded-lg overflow-hidden shrink-0 border border-outline-variant/20">
                    <img class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" src="https://picsum.photos/seed/@reservation.PropertyId/600/400" alt="@reservation.Property?.Title" />
                </div>
                <div class="flex flex-col justify-between flex-1 py-1">
                    <div>
                        <div class="flex justify-between items-start mb-1">
                            <h3 class="text-headline-md font-headline-md text-primary">@reservation.Property?.Title</h3>
                            <span class="px-2.5 py-1 rounded-md text-label-sm font-label-sm border @statusClass">@statusText</span>
                        </div>
                        <p class="text-body-md font-body-md text-on-surface-variant flex items-center gap-1">
                            <span class="material-symbols-outlined text-[18px]">location_on</span>
                            @reservation.Property?.City
                        </p>
                    </div>
                    <div class="grid grid-cols-2 gap-stack-md mt-stack-md bg-surface-container-low/50 p-4 rounded-lg border border-outline-variant/30">
                        <div>
                            <p class="text-label-sm font-label-sm text-on-secondary-container mb-1">CHECK-IN</p>
                            <p class="text-body-md font-body-md font-medium text-primary">@reservation.StayPeriod.CheckIn.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-on-secondary-container mb-1">CHECK-OUT</p>
                            <p class="text-body-md font-body-md font-medium text-primary">@reservation.StayPeriod.CheckOut.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                    <div class="flex gap-stack-sm mt-stack-md justify-end">
                        @if (reservation.Status == ReservationStatus.Confirmed)
                        {
                            <button class="px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface hover:bg-surface-container-low transition-colors">Contact Host</button>
                            <button class="px-4 py-2 bg-primary text-on-primary rounded-lg text-label-md font-label-md hover:opacity-90 transition-opacity">View Itinerary</button>
                        }
                        else if (reservation.Status == ReservationStatus.Pending)
                        {
                            <button class="px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface hover:bg-surface-container-low transition-colors">Cancel Request</button>
                        }
                        else if (reservation.Status == ReservationStatus.Completed)
                        {
                            <button class="px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface hover:bg-surface-container-low transition-colors">Book Again</button>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
}
</div>
</main>