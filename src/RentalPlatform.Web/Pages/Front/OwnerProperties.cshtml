@page
@model RentalPlatform.Web.Pages.Front.OwnerPropertiesModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "Properties - Management Dashboard";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "bg-background text-on-background antialiased font-body-md flex min-h-screen";
    ViewData["FrontNavVariant"] = "owner";
    ViewData["FrontActiveNav"] = "properties";
}

@section Head {
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Level 1 Shadow Custom Utility as per guidelines if standard shadow-sm is too soft, but using standard for compliance */
        .level-1-card {
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        }
    </style>
}

<!-- Main Content Canvas -->
<main class="md:ml-64 flex-1 p-4 md:p-margin-desktop bg-background min-h-screen">
<!-- Header Section -->
<header class="flex flex-col md:flex-row md:items-end justify-between mb-stack-lg gap-stack-md">
<div>
<h1 class="text-display-lg font-display-lg text-on-background mb-2">Properties</h1>
<p class="text-body-md font-body-md text-on-surface-variant">Manage your listings, update availability, and track performance.</p>
</div>
<a href="/Front/PublishEditProperty" class="bg-primary text-on-primary px-6 py-3 rounded-lg text-label-md font-label-md hover:bg-inverse-surface transition-colors flex items-center gap-2 w-fit">
<span class="material-symbols-outlined text-[18px]" data-icon="add">add</span>
                List New Property
            </a>
</header>
<!-- Metrics Overview (Bento-style summary) -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mb-stack-lg">
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant/50 level-1-card">
<p class="text-label-sm font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Total Listings</p>
<p class="text-headline-lg font-headline-lg text-primary">@Model.Properties.Count()</p>
</div>
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant/50 level-1-card">
<p class="text-label-sm font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Active</p>
<p class="text-headline-lg font-headline-lg text-primary">@Model.Properties.Count(p => true)</p>
</div>
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant/50 level-1-card">
<p class="text-label-sm font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Pending/Draft</p>
<p class="text-headline-lg font-headline-lg text-on-surface-variant">0</p>
</div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="mb-stack-md rounded-lg border border-error/30 bg-error-container p-stack-md text-body-md text-error">@Model.ErrorMessage</div>
}

@if (!Model.Properties.Any())
{
    <div class="text-center py-20">
        <p class="text-body-lg text-on-surface-variant">No properties yet. Start by listing your first property!</p>
        <a href="/Front/PublishEditProperty" class="text-primary underline mt-4 inline-block">List New Property</a>
    </div>
}
else
{
    <!-- Properties Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-gutter">
        @foreach (var property in Model.Properties)
        {
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/50 overflow-hidden flex flex-col level-1-card transition-all hover:shadow-md hover:border-outline-variant group">
                <div class="h-48 w-full relative bg-surface-container">
                    <img class="object-cover w-full h-full" src="https://picsum.photos/seed/@property.Id/600/400" alt="@property.Title" />
                    <div class="absolute top-4 right-4 bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm border border-outline-variant/20 flex items-center gap-1">
                        <div class="w-2 h-2 rounded-full @(property.IsActive ? "bg-[#10B981]" : "bg-orange-500")"></div> @(property.IsActive ? "Active" : "Inactive")
                    </div>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-headline-md font-headline-md text-on-background line-clamp-1">@property.Title</h3>
                        <span class="bg-surface-container-low text-on-surface-variant text-label-sm font-label-sm px-2 py-1 rounded">ID: @property.Id.ToString().Substring(0, 4)</span>
                    </div>
                    <p class="text-body-sm font-body-sm text-on-surface-variant mb-4 flex items-center gap-1">
                        <span class="material-symbols-outlined text-[16px]" data-icon="location_on">location_on</span>
                        @property.City
                    </p>
                    <div class="grid grid-cols-2 gap-4 mb-6 py-4 border-y border-outline-variant/30">
<div>
                            <p class="text-label-sm font-label-sm text-on-surface-variant">Price/Night</p>
                            <p class="text-body-lg font-body-lg text-primary font-medium">$@property.PricePerNight.Amount</p>
                        </div>
                        <div>
                            <p class="text-label-sm font-label-sm text-on-surface-variant mb-2">Status</p>
                            <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@property.Id">
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" @(property.IsActive ? "checked" : "") onchange="this.form.submit()">
                                    <div class="w-11 h-6 bg-gray-300 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                    <span class="ml-2 text-sm @(property.IsActive ? "text-primary font-bold" : "text-on-surface-variant")">@(property.IsActive ? "Active" : "Inactive")</span>
                                </label>
                            </form>
                        </div>
                    </div>
                    <div class="mt-auto flex gap-3">
                        <a asp-page="/Front/PublishEditProperty" asp-route-id="@property.Id" class="flex-1 bg-transparent border border-outline-variant text-on-surface-variant text-label-md font-label-md py-2 rounded-lg hover:bg-surface-container-low transition-colors text-center">Edit Listing</a>
                        <a href="/Front/PropertyDetails/@property.Id" class="p-2 border border-outline-variant rounded-lg text-on-surface-variant hover:bg-primary-container hover:text-primary transition-colors" title="View">
                            <span class="material-symbols-outlined" data-icon="visibility">visibility</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
</main>

