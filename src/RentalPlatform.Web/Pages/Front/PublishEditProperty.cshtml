@page
@model RentalPlatform.Web.Pages.Front.PublishEditPropertyModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Publicar Inmueble";
    ViewData["HtmlLang"] = "es";
    ViewData["HtmlClass"] = "light";
    ViewData["BodyClass"] = "bg-surface text-on-surface antialiased min-h-screen flex font-body-md text-body-md";
    ViewData["FrontNavVariant"] = "owner";
    ViewData["FrontActiveNav"] = "publish";
}

@section Head {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, h4, h5, h6, .font-display, .font-headline, .font-label { font-family: 'Geist', sans-serif; }
        
        /* Ambient shadows as per style guidance */
        .ambient-shadow-lvl1 { box-shadow: 0px 1px 3px 0px rgba(15, 23, 42, 0.05); }
        .ambient-shadow-lvl2 { box-shadow: 0px 4px 12px 0px rgba(15, 23, 42, 0.08); }
        .hover-lift:hover { box-shadow: 0px 4px 12px 0px rgba(15, 23, 42, 0.08); border-color: #CBD5E1; transform: translateY(-2px); transition: all 0.2s ease; }
        #map { height: 250px; border-radius: 8px; }
    </style>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-stack-lg">
        <div class="rounded-lg border border-error/30 bg-error-container p-stack-md text-body-md text-error">@Model.ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pt-stack-lg">
        <div class="rounded-lg border border-tertiary/30 bg-tertiary-container p-stack-md text-body-md text-tertiary">@Model.SuccessMessage</div>
    </div>
}

<!-- Main Content Canvas -->
<main class="flex-1 md:ml-64 bg-background min-h-screen">
<!-- Top App Bar for Mobile (Hidden on Desktop) -->
<header class="md:hidden flex items-center justify-between p-margin-mobile bg-surface-container-lowest border-b border-outline-variant sticky top-0 z-40">
<div class="flex items-center gap-2">
<button class="text-on-surface-variant">
<span class="material-symbols-outlined" data-icon="menu">menu</span>
</button>
<span class="text-headline-md font-headline-md font-bold text-primary">LuxeStay</span>
</div>
<div class="w-8 h-8 rounded-full bg-primary-container overflow-hidden">
<img alt="Manager Avatar Mobile" class="w-full h-full object-cover" data-alt="A professional headshot of a property manager in a well-lit, modern corporate environment. The person is smiling confidently, wearing smart business attire. The background is slightly blurred showing subtle architectural lines of an office. The lighting is bright and clean, fitting a high-end corporate identity." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdNL83_zgi0LDNW7lDkX4eiZan2XTQE1j_KeLaoBCXs1pTO3PDmCQSteZUB4X1W5QmXgLT9Elc5dzc1Ut-aUkedbk0w65PSb6s3vcrlYSXXAS8GKynv71FHbWsti2m8YKz-iPecXxRQrx-J7rt2Lo3d8c10-H-lZ-vwokyJ7km0fMUWK-Mc_3-U9eKj1vsht6DEypw2u7crGHGwhMQnMalrpaW0pumxvKIkB5mlZ8uD7K0jByOwMe2B0YLEQdta7X15oJpZunRWsI"/>
</div>
</header>
<div class="max-w-container-max mx-auto p-margin-mobile md:p-margin-desktop space-y-stack-lg">
<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-stack-md border-b border-outline-variant pb-stack-md">
<div>
<div class="flex items-center gap-2 text-on-surface-variant mb-2">
<span class="material-symbols-outlined text-[16px]">arrow_back</span>
<a class="text-label-sm font-label-sm hover:text-primary transition-colors" asp-page="/Front/OwnerProperties">Back to Properties</a>
</div>
<h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary">Publish New Property</h1>
<p class="text-body-md font-body-md text-on-surface-variant mt-1">Add your luxury rental to the platform.</p>
</div>
<div class="flex items-center gap-stack-sm">
<button class="px-4 py-2 text-label-md font-label-md text-secondary border border-outline-variant rounded-lg hover:bg-surface-container-low transition-colors bg-surface-container-lowest" type="button" onclick="history.back()">Cancel</button>
<button class="px-4 py-2 text-label-md font-label-md text-on-primary bg-primary rounded-lg hover:bg-primary/90 transition-colors shadow-sm" form="property-form" type="submit">Publish Property</button>
</div>
</div>
<!-- Form Layout (Bento Grid Style) -->
<form class="grid grid-cols-1 lg:grid-cols-12 gap-gutter" id="property-form" method="post">
<!-- Main Details Column -->
<div class="lg:col-span-8 space-y-gutter">
<!-- Basic Info Card -->
<section class="bg-surface-container-lowest rounded-xl border border-outline-variant p-6 ambient-shadow-lvl1">
<h2 class="text-headline-md font-headline-md text-primary mb-stack-md">Basic Details</h2>
<div class="space-y-stack-md">
<div>
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="Title">Property Title</label>
<input asp-for="Title" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all placeholder-on-surface-variant/50" placeholder="e.g. Modern Loft in Downtown" type="text"/>
</div>
<div>
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="Description">Description</label>
<textarea asp-for="Description" class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all placeholder-on-surface-variant/50" placeholder="Describe the key features and atmosphere..." rows="5"></textarea>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
<div>
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="City">City / Location</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-2.5 text-on-surface-variant text-[20px]">location_on</span>
<input asp-for="City" class="w-full pl-10 pr-3 py-2 bg-surface border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" type="text"/>
</div>
</div>
<div>
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" for="property_type">Property Type</label>
<select class="w-full px-3 py-2 bg-surface border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all appearance-none" id="property_type" name="property_type">
<option selected="" value="villa">Villa</option>
<option value="apartment">Luxury Apartment</option>
<option value="house">House</option>
<option value="estate">Estate</option>
</select>
</div>
</div>
</div>
</section>
<!-- Media Upload Card -->
<section class="bg-surface-container-lowest rounded-xl border border-outline-variant p-6 ambient-shadow-lvl1">
<div class="flex items-center justify-between mb-stack-md">
<h2 class="text-headline-md font-headline-md text-primary">Media Gallery</h2>
<span class="text-label-sm font-label-sm text-on-surface-variant">Photos will use placeholder images</span>
</div>
<!-- Upload Dropzone -->
<div class="border-2 border-dashed border-outline-variant rounded-xl p-8 flex flex-col items-center justify-center text-center bg-surface-container-low mb-stack-md hover:bg-surface-container transition-colors cursor-pointer group">
<span class="material-symbols-outlined text-[32px] text-on-surface-variant mb-2 group-hover:text-primary transition-colors">cloud_upload</span>
<div class="text-label-md font-label-md text-primary mb-1">Click to upload or drag and drop</div>
<div class="text-body-sm font-body-sm text-on-surface-variant">High-resolution JPEG, PNG (max 10MB per image)</div>
</div>
</section>
<!-- Interactive Map Card -->
<section class="bg-surface-container-lowest rounded-xl border border-outline-variant p-6 ambient-shadow-lvl1">
<h2 class="text-headline-md font-headline-md text-primary mb-stack-md">Location Map</h2>
<div id="map" class="w-full bg-surface-container-low border border-outline-variant/30"></div>
<p class="text-body-sm font-body-sm text-on-surface-variant mt-2">Click on the map to set your property location. We'll auto-fill the city.</p>
</section>
</div>
<!-- Sidebar / Secondary Details Column -->
<div class="lg:col-span-4 space-y-gutter">
<!-- Publishing Status Card -->
<section class="bg-surface-container-lowest rounded-xl border border-outline-variant p-6 ambient-shadow-lvl1">
<h2 class="text-headline-md font-headline-md text-primary mb-stack-md border-b border-outline-variant pb-2">Status & Pricing</h2>
<!-- Toggle Switch -->
<div class="flex items-center justify-between mb-stack-lg bg-surface-container-low p-4 rounded-lg border border-outline-variant">
<div>
<div class="text-label-md font-label-md text-primary font-bold">Listing Status</div>
<div class="text-body-sm font-body-sm text-on-surface-variant">Currently visible to guests</div>
</div>
<label class="relative inline-flex items-center cursor-pointer">
<input asp-for="IsActive" checked="" class="sr-only peer" type="checkbox" value="true" />
<input name="IsActive" type="hidden" value="false" />
<div class="w-11 h-6 bg-outline-variant peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
<span class="ml-3 text-label-sm font-label-sm text-primary">Active</span>
</label>
</div>
<!-- Pricing -->
<div class="space-y-stack-md">
<div>
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-1" asp-for="PricePerNight">Base Nightly Rate</label>
<div class="relative">
<span class="absolute left-3 top-2.5 text-on-surface-variant font-label-md">$</span>
<input asp-for="PricePerNight" class="w-full pl-8 pr-3 py-2 bg-surface border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 font-mono transition-all" type="number" step="0.01" min="0"/>
</div>
</div>
</div>
</section>
</div>
</form>
</div>
</main>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var map = L.map('map').setView([4.6097, -74.0817], 13); // Bogotá por defecto
    
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);
    
    var marker;
    
    map.on('click', function(e) {
        var latlng = e.latlng;
        
        if (marker) {
            marker.setLatLng(latlng);
        } else {
            marker = L.marker(latlng).addTo(map);
        }
        
        // Reverse geocoding
        fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latlng.lat}&lon=${latlng.lng}`)
            .then(response => response.json())
            .then(data => {
                if (data && data.address) {
                    var city = data.address.city || data.address.town || data.address.village || data.address.state || '';
                    if (city) {
                        document.getElementById('City').value = city;
                    }
                }
            })
            .catch(err => console.log('Geocoding error:', err));
    });
    
    // Geocode existing city on load
    var cityInput = document.getElementById('City');
    if (cityInput && cityInput.value) {
        fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(cityInput.value)}&format=json&limit=1`)
            .then(response => response.json())
            .then(data => {
                if (data && data[0]) {
                    var lat = parseFloat(data[0].lat);
                    var lon = parseFloat(data[0].lon);
                    map.setView([lat, lon], 13);
                    if (marker) marker.setLatLng([lat, lon]);
                    else marker = L.marker([lat, lon]).addTo(map);
                }
            });
    }
});
</script>
}