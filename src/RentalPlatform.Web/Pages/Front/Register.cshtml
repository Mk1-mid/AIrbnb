@page
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Registro";
    ViewData["HtmlLang"] = "es";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "bg-surface-container-lowest text-on-surface antialiased min-h-screen flex flex-col md:flex-row";
    ViewData["FrontNavVariant"] = "auth";
    ViewData["FrontActiveNav"] = "register";
}

@section Head {
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
}

<div class="hidden md:block md:w-5/12 lg:w-1/2 relative bg-surface-variant">
<div class="absolute inset-0 bg-cover bg-center" data-alt="A striking, high-end architectural photograph of a modern luxury villa living room at dusk. The space features minimalist furniture, large floor-to-ceiling windows overlooking a serene landscape, and warm ambient lighting. The aesthetic is clean, professional, and sophisticated, reflecting a premium short-term rental brand. The color palette relies on neutral tones, deep shadows, and subtle warm highlights." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDg0y4eN6b_cyKyW-1HD6Pp9dtkSWy1eKM43TiVC3CukuKPKwWYxcG6ricPY_WzKxAcke7x8NoYP4PA56Jm1gfIp2J1ggCo_RFQxdET3n-eh0Apc-P-_0Y8rDgFvKd-WUZrRhHpRVjSj0GixcOmfaAxNlVa6LKF3YT2hWS2c88CqDWkLLVf-HpKk5EUDdnsIVy3fyL0HT2pObl_0IPHvlqXfmXEKun65F2NAnvLB8ci5y8febOCPpQ1U2pNfoNTUaMXfwp7L5T-p20')"></div>
<div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent"></div>
<div class="absolute bottom-margin-desktop left-margin-desktop right-margin-desktop text-on-primary">
<h2 class="text-headline-lg font-headline-lg mb-stack-sm text-on-primary">Bienvenido a la excelencia.</h2>
<p class="text-body-lg font-body-lg text-on-primary/80">Únete a la red más exclusiva de propiedades premium.</p>
</div>
</div>
<!-- Form Column -->
<div class="w-full md:w-7/12 lg:w-1/2 flex flex-col justify-center px-margin-mobile md:px-margin-desktop py-stack-lg min-h-screen overflow-y-auto">
<div class="w-full max-w-md mx-auto">
<!-- Brand -->
<div class="mb-stack-lg flex items-center">
<span class="text-headline-md font-headline-md font-bold text-primary">LuxeStay</span>
</div>
<!-- Header -->
<div class="mb-stack-lg">
<h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary mb-stack-sm">Crear una cuenta</h1>
<p class="text-body-md font-body-md text-on-surface-variant">Ingresa tus datos para registrarte.</p>
</div>
<!-- Form -->
<form action="#" class="space-y-stack-md" method="POST">
<!-- Role Selector -->
<div class="mb-stack-lg">
<label class="block text-label-sm font-label-sm text-on-surface-variant mb-stack-sm uppercase tracking-wider">Tipo de cuenta</label>
<div class="grid grid-cols-2 gap-stack-sm bg-surface-container p-1 rounded-lg">
<label class="cursor-pointer">
<input checked="" class="peer sr-only" name="role" type="radio" value="guest"/>
<div class="text-center py-2 rounded-md text-label-md font-label-md transition-all duration-200 peer-checked:bg-surface-container-lowest peer-checked:text-primary peer-checked:shadow-sm text-on-surface-variant hover:text-primary">
                                Huésped
                            </div>
</label>
<label class="cursor-pointer">
<input class="peer sr-only" name="role" type="radio" value="owner"/>
<div class="text-center py-2 rounded-md text-label-md font-label-md transition-all duration-200 peer-checked:bg-surface-container-lowest peer-checked:text-primary peer-checked:shadow-sm text-on-surface-variant hover:text-primary">
                                Propietario
                            </div>
</label>
</div>
</div>
<!-- Name & Surname -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-base" for="name">Nombre</label>
<input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" id="name" name="name" placeholder="Tu nombre" required="" type="text"/>
</div>
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-base" for="surname">Apellidos</label>
<input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" id="surname" name="surname" placeholder="Tus apellidos" required="" type="text"/>
</div>
</div>
<!-- Email -->
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-base" for="email">Correo electrónico</label>
<input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" id="email" name="email" placeholder="nombre&#64;ejemplo.com" required="" type="email"/>
</div>
<!-- Password -->
<div>
<label class="block text-label-sm font-label-sm text-on-surface mb-base" for="password">Contraseña</label>
<div class="relative">
<input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:border-primary focus:ring-2 focus:ring-secondary-fixed focus:outline-none transition-colors" id="password" name="password" placeholder="••••••••" required="" type="password"/>
<button class="absolute inset-y-0 right-0 pr-3 flex items-center text-on-surface-variant hover:text-primary transition-colors" type="button">
<span class="material-symbols-outlined text-[20px]">visibility_off</span>
</button>
</div>
<p class="mt-2 text-label-sm font-label-sm text-on-surface-variant">Debe contener al menos 8 caracteres.</p>
</div>
<!-- Submit Action -->
<div class="pt-stack-md">
<button class="w-full flex justify-center items-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-label-md font-label-md text-on-primary bg-primary hover:bg-inverse-surface focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors" type="submit">
                        Completar registro
                    </button>
</div>
</form>
<!-- Footer Links -->
<div class="mt-stack-lg text-center">
<p class="text-body-sm font-body-sm text-on-surface-variant">
                    ¿Ya tienes una cuenta? 
                    <a class="font-bold text-primary hover:underline transition-all" href="#">Inicia sesión</a>
</p>
<p class="mt-stack-sm text-label-sm font-label-sm text-outline">
                    Al registrarte, aceptas nuestros <a class="underline hover:text-primary transition-colors" href="#">Términos</a> y <a class="underline hover:text-primary transition-colors" href="#">Política de Privacidad</a>.
                </p>
</div>
</div>
</div>

