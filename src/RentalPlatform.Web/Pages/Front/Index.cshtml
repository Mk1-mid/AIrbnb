@page
@model RentalPlatform.Web.Pages.Front.IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["FrontNavVariant"] = "public";
    ViewData["FrontActiveNav"] = "browse";
}

<section class="w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
    <header class="flex flex-col gap-2 mb-8">
        <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary">Curated Stays</h1>
        <p class="text-body-md font-body-md text-on-surface-variant">Discover exceptional properties tailored for discerning travelers.</p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter">
        <article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 ambient-shadow-lvl1-hover transition-all duration-200 group cursor-pointer flex flex-col">
            <div class="relative w-full h-64 overflow-hidden">
                <div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-500" style="background-image: url('https://picsum.photos/seed/villa1/600/400')"></div>
                <button class="absolute top-3 right-3 p-2 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm hover:bg-surface-container-lowest transition-colors text-on-surface-variant hover:text-error">
                    <span class="material-symbols-outlined text-[20px]">favorite</span>
                </button>
                <div class="absolute bottom-3 left-3 bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-primary">Superhost</div>
            </div>
            <div class="p-stack-md flex flex-col flex-1">
                <div class="flex justify-between items-start mb-1">
                    <h2 class="text-body-lg font-body-lg font-semibold text-primary truncate pr-2">The Glass House Retreat</h2>
                    <div class="flex items-center gap-1 text-label-sm font-label-sm">
                        <span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span>4.98</span>
                    </div>
                </div>
                <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Kyoto, Japan</p>
                <div class="mt-auto pt-stack-sm border-t border-surface-container-highest flex justify-between items-end">
                    <div>
                        <span class="text-body-lg font-body-lg font-semibold text-primary">$450</span>
                        <span class="text-body-sm font-body-sm text-on-surface-variant"> / night</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">WiFi</span>
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">Pool</span>
                    </div>
                </div>
            </div>
        </article>

        <article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 ambient-shadow-lvl1-hover transition-all duration-200 group cursor-pointer flex flex-col">
            <div class="relative w-full h-64 overflow-hidden">
                <div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-500" style="background-image: url('https://picsum.photos/seed/loft1/600/400')"></div>
                <button class="absolute top-3 right-3 p-2 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm hover:bg-surface-container-lowest transition-colors text-on-surface-variant hover:text-error">
                    <span class="material-symbols-outlined text-[20px]">favorite</span>
                </button>
            </div>
            <div class="p-stack-md flex flex-col flex-1">
                <div class="flex justify-between items-start mb-1">
                    <h2 class="text-body-lg font-body-lg font-semibold text-primary truncate pr-2">Urban Minimalist Loft</h2>
                    <div class="flex items-center gap-1 text-label-sm font-label-sm">
                        <span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span>4.85</span>
                    </div>
                </div>
                <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Berlin, Germany</p>
                <div class="mt-auto pt-stack-sm border-t border-surface-container-highest flex justify-between items-end">
                    <div>
                        <span class="text-body-lg font-body-lg font-semibold text-primary">$180</span>
                        <span class="text-body-sm font-body-sm text-on-surface-variant"> / night</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">Gym</span>
                    </div>
                </div>
            </div>
        </article>

        <article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 ambient-shadow-lvl1-hover transition-all duration-200 group cursor-pointer flex flex-col">
            <div class="relative w-full h-64 overflow-hidden">
                <div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-500" style="background-image: url('https://picsum.photos/seed/cliff1/600/400')"></div>
                <button class="absolute top-3 right-3 p-2 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm hover:bg-surface-container-lowest transition-colors text-on-surface-variant hover:text-error">
                    <span class="material-symbols-outlined text-[20px]">favorite</span>
                </button>
                <div class="absolute bottom-3 left-3 bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-primary">Rare Find</div>
            </div>
            <div class="p-stack-md flex flex-col flex-1">
                <div class="flex justify-between items-start mb-1">
                    <h2 class="text-body-lg font-body-lg font-semibold text-primary truncate pr-2">Cliffside Ocean View</h2>
                    <div class="flex items-center gap-1 text-label-sm font-label-sm">
                        <span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span>5.0</span>
                    </div>
                </div>
                <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Santorini, Greece</p>
                <div class="mt-auto pt-stack-sm border-t border-surface-container-highest flex justify-between items-end">
                    <div>
                        <span class="text-body-lg font-body-lg font-semibold text-primary">$850</span>
                        <span class="text-body-sm font-body-sm text-on-surface-variant"> / night</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">View</span>
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">Pool</span>
                    </div>
                </div>
            </div>
        </article>

        <article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 ambient-shadow-lvl1-hover transition-all duration-200 group cursor-pointer flex flex-col">
            <div class="relative w-full h-64 overflow-hidden">
                <div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-500" style="background-image: url('https://picsum.photos/seed/cabin1/600/400')"></div>
                <button class="absolute top-3 right-3 p-2 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm hover:bg-surface-container-lowest transition-colors text-on-surface-variant hover:text-error">
                    <span class="material-symbols-outlined text-[20px]">favorite</span>
                </button>
            </div>
            <div class="p-stack-md flex flex-col flex-1">
                <div class="flex justify-between items-start mb-1">
                    <h2 class="text-body-lg font-body-lg font-semibold text-primary truncate pr-2">Geometric Pine Cabin</h2>
                    <div class="flex items-center gap-1 text-label-sm font-label-sm">
                        <span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
                        <span>4.92</span>
                    </div>
                </div>
                <p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Aspen, Colorado</p>
                <div class="mt-auto pt-stack-sm border-t border-surface-container-highest flex justify-between items-end">
                    <div>
                        <span class="text-body-lg font-body-lg font-semibold text-primary">$320</span>
                        <span class="text-body-sm font-body-sm text-on-surface-variant"> / night</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">Fireplace</span>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>
