@page
@model RentalPlatform.Web.Pages.Front.IndexModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Explore Properties";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "";
    ViewData["BodyClass"] = "min-h-screen flex flex-col";
    ViewData["FrontNavVariant"] = "public";
    ViewData["FrontActiveNav"] = "browse";
}

@section Head {
<style>
        body {
            background-color: theme('colors.background');
            color: theme('colors.on-background');
        }
        .ambient-shadow-lvl1 {
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        }
        .ambient-shadow-lvl1-hover:hover {
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
            border-color: theme('colors.outline');
        }
    </style>
}

<!-- Main Content -->
<main class="flex-1 w-full max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-stack-lg">
<!-- Header & Filters -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-stack-lg gap-stack-md">
<div>
<h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary mb-2">Curated Stays</h1>
<p class="text-body-md font-body-md text-on-surface-variant">Discover exceptional properties tailored for discerning travelers.</p>
</div>
<div class="flex items-center gap-stack-sm overflow-x-auto pb-2 w-full md:w-auto scrollbar-hide">
<button class="flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low transition-colors whitespace-nowrap">
<span class="material-symbols-outlined text-[18px]">tune</span>
                    Filters
                </button>
<button class="flex items-center gap-2 px-4 py-2 bg-surface-container-low border border-outline-variant rounded-lg text-label-md font-label-md text-primary font-bold whitespace-nowrap">
                    All Homes
                </button>
<button class="flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low transition-colors whitespace-nowrap">
                    Villas
                </button>
<button class="flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-lg text-label-md font-label-md text-on-surface-variant hover:bg-surface-container-low transition-colors whitespace-nowrap">
                    Apartments
                </button>
</div>
</div>
<!-- Bento Grid / Property Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter">
<!-- Card 1 -->
<article class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden ambient-shadow-lvl1 ambient-shadow-lvl1-hover transition-all duration-200 group cursor-pointer flex flex-col">
<div class="relative w-full h-64 overflow-hidden">
<div class="w-full h-full bg-cover bg-center group-hover:scale-105 transition-transform duration-500" data-alt="A breathtaking view of a modern luxury villa exterior at twilight. Floor-to-ceiling glass windows revealing warm interior lighting. Infinity pool reflecting the sunset. High-end architectural photography, minimalist and corporate trust aesthetic." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCbKVeKX6DRDLuAnh5SrYfkXGE-HGAhgcYmmSF_8gUAgE85WrE5gZvvs8N_bISpwmRnNkdqgc8niIkFmEma50HOFhAK22e_RWrlsIIc0XJMJ3GxUhTZu7T80uswKqtL9NGLBq7b_VyybS-mkF_cW47g96aUBNLHQJGommcIUle7pJmqDGkYJMg_ubD6GWuq_kCEc5kka7iiVZxUeUTnmtLkGx3cFrAF2LEY0OCqWln4MVjT0IHwtEiiE9ZmuVbcNRwspRlRD0KzUqw')"></div>
<button class="absolute top-3 right-3 p-2 rounded-full bg-surface-container-lowest/80 backdrop-blur-sm hover:bg-surface-container-lowest transition-colors text-on-surface-variant hover:text-error">
<span class="material-symbols-outlined text-[20px]">favorite</span>
</button>
<div class="absolute bottom-3 left-3 bg-surface-container-lowest/90 backdrop-blur-sm px-2 py-1 rounded text-label-sm font-label-sm text-primary">
                        Superhost
                    </div>
</div>
<div class="p-stack-md flex flex-col flex-1">
<div class="flex justify-between items-start mb-1">
<h2 class="text-body-lg font-body-lg font-semibold text-primary truncate pr-2">The Glass House Retreat</h2>
<div class="flex items-center gap-1 text-label-sm font-label-sm">
<span class="material-symbols-outlined text-[16px] text-primary" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
<span>4.98</span>
</div>
</div>
<p class="text-body-sm font-body-sm text-on-surface-variant mb-4">Kyoto, Japan</p>
<div class="mt-auto pt-stack-sm border-t border-surface-container-highest flex justify-between items-end">
<div>
<span class="text-body-lg font-body-lg font-semibold text-primary">$450</span>
<span class="text-body-sm font-body-sm text-on-surface-variant"> / night</span>
</div>
<div class="flex gap-2">
<span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">WiFi</span>
<span class="bg-surface-container-low px-2 py-1 rounded text-label-sm font-label-sm text-on-surface-variant">Pool</span>
</div>
</div>
</div>
</article>
