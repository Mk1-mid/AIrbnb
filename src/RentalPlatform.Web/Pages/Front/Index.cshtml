@page
@model RentalPlatform.Web.Pages.Front.IndexModel
@{
    ViewData["Title"] = "LuxeStay - Discover";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "dark";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md antialiased overflow-x-hidden min-h-screen flex flex-col";
    ViewData["FrontNavVariant"] = "public";
    ViewData["FrontActiveNav"] = "browse";
}

@section Head {
<style>
    .glass-panel {
        background-color: rgba(11, 27, 43, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .golden-glow {
        box-shadow: 0 0 20px 0 rgba(242, 202, 80, 0.15);
    }
    .golden-glow-focus:focus-within {
        box-shadow: 0 0 20px 0 rgba(242, 202, 80, 0.15);
    }
    .text-glow {
        text-shadow: 0 0 10px rgba(242, 202, 80, 0.3);
    }
    .hide-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
}

<main class="flex-grow">
<section class="relative w-full min-h-[819px] flex items-center justify-center pt-2xl pb-xl px-margin-desktop md:px-margin-desktop overflow-hidden">
<div class="absolute inset-0 bg-gradient-to-b from-[#0B1B2B] via-background to-background z-0"></div>
<div class="absolute inset-0 opacity-10 mix-blend-overlay z-0 bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCZvstGLhjBk-xBMaRqUmj9rD-v8RG45VflQb_nuywZAMLaV7gm3ZGEw26rM4hOL9dD0_wSDZFCA3gfOk3kYjORmJ4a--UEYBW6LkOG9R1Nv8iY_CITfo3QcTs7HHpUarsC9_zmgh69kauEaRRZDDBZ9fqnMTV8p8G-Q5TxkO6a9_ropY4enKgaGgPQRh1Dy8WIgpyL6kEsJGSKKf35bD5oReh8_M5KksEIAoUMQtPf3DCHaVm3mQSJl3jfh4voMQF6M8ayblzjXr8')"></div>
<div class="relative z-10 w-full max-w-7xl flex flex-col items-center text-center">
<h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface mb-sm text-glow">Unveil Your Next Sanctuary</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mb-xl">Curated collection of world-class estates for the discerning traveler.</p>
<div class="w-full max-w-5xl glass-panel border border-primary/30 rounded-xl p-md shadow-2xl golden-glow-focus transition-all duration-300 mb-lg">
<form class="flex flex-col md:flex-row gap-sm items-stretch">
<div class="flex-1 relative flex items-center bg-surface-container-low rounded-lg border border-transparent focus-within:border-primary/50 transition-colors group">
<span class="material-symbols-outlined absolute left-md text-on-surface-variant group-focus-within:text-primary">location_on</span>
<div class="w-full flex flex-col justify-center px-md pl-[52px] py-sm">
<label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest transition-all group-focus-within:text-primary" for="destination">Destination</label>
<input class="w-full bg-transparent border-none p-0 focus:ring-0 text-on-surface font-body-md placeholder-on-surface-variant/50" id="destination" placeholder="Where are you going?" type="text" />
</div>
</div>
<div class="hidden md:block w-px bg-outline-variant/20 my-sm"></div>
<div class="flex-1 relative flex items-center bg-surface-container-low rounded-lg border border-transparent focus-within:border-primary/50 transition-colors group">
<span class="material-symbols-outlined absolute left-md text-on-surface-variant group-focus-within:text-primary">calendar_month</span>
<div class="w-full flex flex-col justify-center px-md pl-[52px] py-sm">
<label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest transition-all group-focus-within:text-primary" for="dates">Dates</label>
<input class="w-full bg-transparent border-none p-0 focus:ring-0 text-on-surface font-body-md placeholder-on-surface-variant/50" id="dates" placeholder="Check in - Check out" type="text" />
</div>
</div>
<div class="hidden md:block w-px bg-outline-variant/20 my-sm"></div>
<div class="flex-1 relative flex items-center bg-surface-container-low rounded-lg border border-transparent focus-within:border-primary/50 transition-colors group">
<span class="material-symbols-outlined absolute left-md text-on-surface-variant group-focus-within:text-primary">person</span>
<div class="w-full flex flex-col justify-center px-md pl-[52px] py-sm">
<label class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest transition-all group-focus-within:text-primary" for="guests">Guests</label>
<input class="w-full bg-transparent border-none p-0 focus:ring-0 text-on-surface font-body-md placeholder-on-surface-variant/50" id="guests" placeholder="Add guests" type="text" />
</div>
</div>
<button class="bg-primary hover:bg-primary-container text-on-primary font-label-md text-label-md uppercase tracking-widest py-md px-lg rounded-lg transition-colors flex items-center justify-center whitespace-nowrap mt-sm md:mt-0 shadow-[0_0_15px_rgba(242,202,80,0.3)] hover:shadow-[0_0_25px_rgba(242,202,80,0.5)]" type="submit">
Check Availability
</button>
</form>
</div>
<div class="w-full max-w-5xl overflow-x-auto hide-scrollbar py-sm">
<div class="flex space-x-sm md:justify-center min-w-max px-margin-mobile md:px-0">
<button class="px-md py-sm rounded-full bg-surface-container border border-primary text-primary font-label-md text-label-md transition-all golden-glow">Private Islands</button>
<button class="px-md py-sm rounded-full bg-surface-container border border-outline-variant/50 text-on-surface-variant hover:border-primary/50 hover:text-on-surface font-label-md text-label-md transition-all">Alpine Chalets</button>
<button class="px-md py-sm rounded-full bg-surface-container border border-outline-variant/50 text-on-surface-variant hover:border-primary/50 hover:text-on-surface font-label-md text-label-md transition-all">Desert Oases</button>
<button class="px-md py-sm rounded-full bg-surface-container border border-outline-variant/50 text-on-surface-variant hover:border-primary/50 hover:text-on-surface font-label-md text-label-md transition-all">Historical Estates</button>
<button class="px-md py-sm rounded-full bg-surface-container border border-outline-variant/50 text-on-surface-variant hover:border-primary/50 hover:text-on-surface font-label-md text-label-md transition-all">Penthouse Suites</button>
</div>
</div>
</div>
</section>
<section class="w-full px-margin-desktop py-xl bg-background">
<div class="max-w-7xl mx-auto">
<div class="flex justify-between items-end mb-lg">
<div>
<h2 class="font-headline-md text-headline-md text-on-surface mb-xs">Featured Sanctuaries</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Handpicked for unparalleled exclusivity and design.</p>
</div>
<button class="hidden md:flex items-center text-primary font-label-md text-label-md uppercase tracking-widest hover:text-primary-container transition-colors group">
View All <span class="material-symbols-outlined ml-xs group-hover:translate-x-1 transition-transform">arrow_forward</span>
</button>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
<div class="group relative flex flex-col bg-surface-container-low border border-outline-variant/30 rounded-xl overflow-hidden hover:border-primary/50 transition-colors duration-500 hover:golden-glow">
<div class="relative aspect-[3/4] overflow-hidden">
<img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_U11z2F35lx9choQCUFO2oBIxir0Tsg16Do0-hk1vaDQQCLIpKBYCkZnEv34AzNWYTK52tiMlJlYr6Dl49MUg-DRu1rTU7gYh4FUwLWOA-AuULjRyeK_qoyQ-Xqk_8BQnrCcrFyrn3hP4s4EYwgFWDTxgolTX4PQFbOB2TQU6rIv5w9Oooj6Ty-KBEZqBEubOonEjyrkwrxl-ZaLkyRmigLfwjHm6406cDhB_ukvQyZZ0DicYRJI8EXz9WQPacHAhBHxsyD7JhxM" alt="Villa Azure" />
<div class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent"></div>
<div class="absolute top-md left-md bg-surface-container/80 backdrop-blur-md border border-primary px-sm py-xs rounded flex items-center">
<span class="material-symbols-outlined text-[14px] text-primary mr-xs">verified</span>
<span class="font-label-sm text-label-sm text-primary uppercase tracking-widest">Luxe Verified</span>
</div>
<button class="absolute top-md right-md p-sm bg-surface-container/50 backdrop-blur-md rounded-full border border-outline-variant/30 text-on-surface hover:text-primary hover:border-primary transition-all">
<span class="material-symbols-outlined">favorite</span>
</button>
<div class="absolute bottom-0 left-0 w-full p-md">
<h3 class="font-headline-sm text-headline-sm text-on-surface mb-xs drop-shadow-md">Villa Azure</h3>
<p class="font-body-md text-body-md text-outline flex items-center">
<span class="material-symbols-outlined text-[16px] mr-xs">location_on</span> Amalfi Coast, Italy
</p>
</div>
</div>
<div class="p-md flex justify-between items-center border-t border-outline-variant/20 bg-surface-container-low">
<div>
<p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest mb-xs">Starting from</p>
<p class="font-headline-sm text-headline-sm text-primary">$12,500 <span class="font-body-md text-body-md text-on-surface-variant">/ night</span></p>
</div>
<a class="px-md py-sm border border-primary/50 text-primary font-label-sm text-label-sm uppercase tracking-widest rounded hover:bg-primary/10 transition-colors" asp-page="/Front/PropertyDetails" asp-route-PropertyId="00000000-0000-0000-0000-000000000001">View Details</a>
</div>
</div>
</div>
</div>
</section>
<section class="w-full px-margin-desktop py-xl bg-surface-container-lowest border-t border-outline-variant/10 relative overflow-hidden">
<div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
<div class="max-w-7xl mx-auto relative z-10">
<div class="text-center mb-xl">
<h2 class="font-headline-md text-headline-md text-on-surface mb-sm">Bespoke Experiences</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">Beyond the estate. Elevate your journey with our curated selection of premium services.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-md">
<div class="glass-panel border border-outline-variant/20 rounded-xl p-lg hover:border-primary/40 transition-all duration-300 group cursor-pointer flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-surface-container border border-primary/30 flex items-center justify-center mb-md group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(242,202,80,0.1)] group-hover:shadow-[0_0_20px_rgba(242,202,80,0.3)]">
<span class="material-symbols-outlined text-[32px] text-primary">flight</span>
</div>
<h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">Private Aviation</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-md flex-grow">Seamless global transit. Access a fleet of light to ultra-long-range jets.</p>
<span class="font-label-sm text-label-sm text-primary uppercase tracking-widest group-hover:underline underline-offset-4">Inquire Now</span>
</div>
<div class="glass-panel border border-outline-variant/20 rounded-xl p-lg hover:border-primary/40 transition-all duration-300 group cursor-pointer flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-surface-container border border-primary/30 flex items-center justify-center mb-md group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(242,202,80,0.1)] group-hover:shadow-[0_0_20px_rgba(242,202,80,0.3)]">
<span class="material-symbols-outlined text-[32px] text-primary">sailing</span>
</div>
<h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">Yacht Charter</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-md flex-grow">Command the seas. Fully crewed superyachts available across the Mediterranean.</p>
<span class="font-label-sm text-label-sm text-primary uppercase tracking-widest group-hover:underline underline-offset-4">Inquire Now</span>
</div>
<div class="glass-panel border border-outline-variant/20 rounded-xl p-lg hover:border-primary/40 transition-all duration-300 group cursor-pointer flex flex-col items-center text-center">
<div class="w-16 h-16 rounded-full bg-surface-container border border-primary/30 flex items-center justify-center mb-md group-hover:scale-110 transition-transform duration-500 shadow-[0_0_15px_rgba(242,202,80,0.1)] group-hover:shadow-[0_0_20px_rgba(242,202,80,0.3)]">
<span class="material-symbols-outlined text-[32px] text-primary">concierge</span>
</div>
<h3 class="font-headline-sm text-headline-sm text-on-surface mb-sm">24/7 Concierge</h3>
<p class="font-body-md text-body-md text-on-surface-variant mb-md flex-grow">Anticipatory service. From private Michelin-starred chefs to exclusive events.</p>
<span class="font-label-sm text-label-sm text-primary uppercase tracking-widest group-hover:underline underline-offset-4">Inquire Now</span>
</div>
</div>
</div>
</section>
</main>
