@page
@model RentalPlatform.Web.Pages.Front.SignInModel
@{
    ViewData["Title"] = "Portal - LuxeStay";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "dark";
    ViewData["BodyClass"] = "bg-background text-on-background font-body-md antialiased min-h-screen flex flex-col md:flex-row";
    ViewData["FrontNavVariant"] = "auth";
    ViewData["FrontActiveNav"] = "signin";
}

@section Head {
<style>
    .glass-panel {
        background-color: rgba(11, 27, 43, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
</style>
}

<!-- Side Image (Desktop) -->
<div class="hidden md:block md:w-1/2 lg:w-5/12 relative bg-surface-variant">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDg0y4eN6b_cyKyW-1HD6Pp9dtkSWy1eKM43TiVC3CukuKPKwWYxcG6ricPY_WzKxAcke7x8NoYP4PA56Jm1gfIp2J1ggCo_RFQxdET3n-eh0Apc-P-_0Y8rDgFvKd-WUZrRhHpRVjSj0GixcOmfaAxNlVa6LKF3YT2hWS2c88CqDWkLLVf-HpKk5EUDdnsIVy3fyL0HT2pObl_0IPHvlqXfmXEKun65F2NAnvLB8ci5y8febOCPpQ1U2pNfoNTUaMXfwp7L5T-p20')"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent"></div>
    <div class="absolute bottom-margin-desktop left-margin-desktop right-margin-desktop text-on-primary">
        <h2 class="text-headline-lg font-headline-lg mb-stack-sm text-on-primary">Welcome to LuxeStay.</h2>
        <p class="text-body-lg font-body-lg text-on-primary/80">Your gateway to exceptional sanctuaries worldwide.</p>
    </div>
</div>

<!-- Form Column -->
<div class="w-full md:w-7/12 lg:w-1/2 flex flex-col justify-center px-margin-mobile md:px-margin-desktop py-stack-lg min-h-screen overflow-y-auto">
    <div class="w-full max-w-md mx-auto">
        <div class="mb-stack-lg flex items-center">
            <span class="text-headline-md font-headline-md font-bold text-primary">LuxeStay</span>
        </div>
        <div class="mb-stack-lg">
            <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-primary mb-stack-sm">Welcome Back</h1>
            <p class="text-body-md font-body-md text-on-surface-variant">Sign in to access your sanctuary account.</p>
        </div>

        @if (Model.Result is not null)
        {
            <div class="mb-stack-md rounded-lg border border-secondary-container bg-secondary-container p-stack-md text-body-sm text-on-secondary-container">
                Login OK. Token generated for @Model.Result.Email as @Model.Result.Role.
            </div>
            <pre class="mb-stack-md overflow-x-auto rounded-lg bg-surface-container-low p-stack-md text-xs">@Model.Result.Token</pre>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-stack-md rounded-lg border border-error/30 bg-error-container p-stack-md text-body-sm text-error">@Model.ErrorMessage</div>
        }

        <form class="flex flex-col gap-stack-md" method="post">
            <div class="space-y-1">
                <label class="text-label-md font-label-md text-on-surface block" asp-for="Email"></label>
                <input asp-for="Email" class="w-full px-3 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest" />
            </div>
            <div class="space-y-1">
                <label class="text-label-md font-label-md text-on-surface block" asp-for="Password"></label>
                <input asp-for="Password" class="w-full px-3 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest" type="password" />
            </div>
            <button class="mt-4 w-full bg-primary text-on-primary py-3 px-4 rounded-lg text-label-md font-label-md hover:bg-primary-container transition-all shadow-[0_0_15px_rgba(242,202,80,0.3)]" type="submit">
                Sign In
            </button>
        </form>
    </div>
</div>
