@page
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "LuxeStay - Sign In";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "light";
    ViewData["BodyClass"] = "bg-background min-h-screen flex flex-col font-body-md text-on-background antialiased ambient-pattern";
    ViewData["FrontNavVariant"] = "auth";
    ViewData["FrontActiveNav"] = "signin";
}

@section Head {
<style>
        /* Ambient Background Pattern */
        .ambient-pattern {
            background-color: #f8f9ff;
            background-image: radial-gradient(#dce9ff 1px, transparent 1px);
            background-size: 24px 24px;
        }
    </style>
}

<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center p-margin-mobile md:p-margin-desktop">
<div class="w-full max-w-[440px] bg-surface-container-lowest rounded-xl border border-outline-variant/30 shadow-[0_4px_12px_rgba(15,23,42,0.08)] p-stack-lg md:p-10 relative overflow-hidden">
<!-- Decorative Accent -->
<div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-tertiary-fixed-dim"></div>
<!-- Form Header -->
<div class="text-center mb-stack-lg">
<h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-on-surface mb-stack-sm tracking-tight">Welcome Back</h1>
<p class="text-body-sm font-body-sm text-on-surface-variant">Sign in to manage your bookings and properties.</p>
</div>
<!-- Login Form -->
<form action="#" class="flex flex-col gap-stack-md" method="POST">
<div class="space-y-1">
<label class="text-label-md font-label-md text-on-surface block" for="email">Email Address</label>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-on-surface-variant/70 text-lg">mail</span>
</div>
<input class="w-full pl-10 pr-3 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:ring-2 focus:ring-secondary-fixed focus:border-primary transition-all placeholder:text-on-surface-variant/50" id="email" name="email" placeholder="name&#64;example.com" required="" type="email"/>
</div>
</div>
<div class="space-y-1">
<div class="flex justify-between items-center">
<label class="text-label-md font-label-md text-on-surface block" for="password">Password</label>
<a class="text-label-sm font-label-sm text-primary hover:underline" href="#">Forgot password?</a>
</div>
<div class="relative">
<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-on-surface-variant/70 text-lg">lock</span>
</div>
<input class="w-full pl-10 pr-10 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest focus:ring-2 focus:ring-secondary-fixed focus:border-primary transition-all placeholder:text-on-surface-variant/50" id="password" name="password" placeholder="••••••••" required="" type="password"/>
<button class="absolute inset-y-0 right-0 pr-3 flex items-center text-on-surface-variant/70 hover:text-primary transition-colors focus:outline-none" type="button">
<span class="material-symbols-outlined text-lg">visibility_off</span>
</button>
</div>
</div>
<div class="flex items-center mt-2">
<input class="h-4 w-4 rounded border-outline-variant/50 text-primary focus:ring-primary bg-surface-container-lowest" id="remember-me" name="remember-me" type="checkbox"/>
<label class="ml-2 block text-body-sm font-body-sm text-on-surface-variant" for="remember-me">
                        Remember me for 30 days
                    </label>
</div>
<button class="mt-4 w-full bg-primary text-on-primary py-3 px-4 rounded-lg text-label-md font-label-md hover:bg-inverse-surface transition-all shadow-[0_1px_3px_rgba(15,23,42,0.1)] hover:shadow-[0_2px_6px_rgba(15,23,42,0.15)] flex justify-center items-center gap-2 group" type="submit">
                    Sign In
                    <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
</button>
</form>
<!-- Divider -->
<div class="mt-stack-lg mb-stack-md relative">
<div class="absolute inset-0 flex items-center">
<div class="w-full border-t border-outline-variant/30"></div>
</div>
<div class="relative flex justify-center text-sm">
<span class="px-2 bg-surface-container-lowest text-label-sm font-label-sm text-on-surface-variant">Or continue with</span>
</div>
</div>
<!-- Social Logins -->
<div class="grid grid-cols-2 gap-stack-sm">
<button class="w-full flex justify-center items-center gap-2 py-2.5 px-4 border border-outline-variant/50 rounded-lg bg-transparent text-label-md font-label-md text-on-surface hover:bg-surface-container-low transition-colors" type="button">
<svg aria-hidden="true" class="h-5 w-5" viewbox="0 0 24 24">
<path d="M12.0003 4.75C13.7703 4.75 15.3553 5.36002 16.6053 6.54998L20.0303 3.125C17.9502 1.19 15.2353 0 12.0003 0C7.31028 0 3.25527 2.69 1.28027 6.60998L5.27028 9.70498C6.21525 6.86002 8.87028 4.75 12.0003 4.75Z" fill="#EA4335"></path>
<path d="M23.49 12.275C23.49 11.49 23.415 10.73 23.3 10H12V14.51H18.47C18.18 15.99 17.34 17.25 16.08 18.1L19.945 21.1C22.2 19.01 23.49 15.92 23.49 12.275Z" fill="#4285F4"></path>
<path d="M5.26498 14.2949C5.02498 13.5699 4.88501 12.7999 4.88501 11.9999C4.88501 11.1999 5.01998 10.4299 5.26498 9.7049L1.275 6.60986C0.46 8.22986 0 10.0599 0 11.9999C0 13.9399 0.46 15.7699 1.28 17.3899L5.26498 14.2949Z" fill="#FBBC05"></path>
<path d="M12.0004 24.0001C15.2404 24.0001 17.9654 22.935 19.9454 21.095L16.0804 18.095C15.0054 18.82 13.6204 19.245 12.0004 19.245C8.8704 19.245 6.21537 17.135 5.26537 14.29L1.27539 17.385C3.25539 21.31 7.3104 24.0001 12.0004 24.0001Z" fill="#34A853"></path>
</svg>
                    Google
                </button>
<button class="w-full flex justify-center items-center gap-2 py-2.5 px-4 border border-outline-variant/50 rounded-lg bg-transparent text-label-md font-label-md text-on-surface hover:bg-surface-container-low transition-colors" type="button">
<svg aria-hidden="true" class="h-5 w-5 fill-current" viewbox="0 0 24 24">
<path d="M16.365 21.44a8.19 8.19 0 0 0 2.22-5.74c0-4.63-3.77-8.39-8.41-8.39-4.63 0-8.4 3.76-8.4 8.39 0 4.22 3.1 7.72 7.15 8.29v-6.02h-2.14v-2.27h2.14v-1.6c0-2.11 1.25-3.28 3.17-3.28.93 0 1.9.17 1.9.17v2.1h-1.07c-1.05 0-1.39.66-1.39 1.34v1.27h2.37l-.38 2.27h-1.99v6.02c1.94-.27 3.69-1.25 4.86-2.75z"></path>
</svg>
                    Apple
                </button>
</div>
<!-- Registration Link -->
<div class="mt-stack-lg text-center">
<p class="text-body-sm font-body-sm text-on-surface-variant">
                    Don't have an account? 
                    <a class="text-label-sm font-label-sm text-primary hover:underline font-semibold ml-1" href="#">Create one now</a>
</p>
</div>
</div>
</main>
<!-- Footer -->
<footer class="w-full bottom-0 bg-surface-container-lowest border-t border-outline-variant mt-auto">
<div class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-stack-lg max-w-container-max mx-auto gap-stack-md">
<div class="text-label-md font-label-md font-bold text-primary">
                © 2024 LuxeStay Rentals. All rights reserved.
            </div>
<div class="flex gap-stack-md">
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Terms</a>
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Privacy</a>
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Sitemap</a>
<a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-opacity duration-200" href="#">Support</a>
</div>
</div>
</footer>

