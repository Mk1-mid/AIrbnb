@page
@model RentalPlatform.Web.Pages.Front.SignInModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "RentalPlatform - Sign In";
    ViewData["HtmlLang"] = "en";
    ViewData["HtmlClass"] = "light";
    ViewData["BodyClass"] = "bg-background min-h-screen flex flex-col font-body-md text-on-background antialiased ambient-pattern";
    ViewData["FrontNavVariant"] = "auth";
    ViewData["FrontActiveNav"] = "signin";
}

@section Head {
<style>
    .ambient-pattern {
        background-color: #f8f9ff;
        background-image: radial-gradient(#dce9ff 1px, transparent 1px);
        background-size: 24px 24px;
    }
</style>
}

<main class="flex-grow flex items-center justify-center p-margin-mobile md:p-margin-desktop">
    <div class="w-full max-w-[440px] bg-surface-container-lowest rounded-xl border border-outline-variant/30 shadow-[0_4px_12px_rgba(15,23,42,0.08)] p-stack-lg md:p-10 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-tertiary-fixed-dim"></div>
        <div class="text-center mb-stack-lg">
            <h1 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-on-surface mb-stack-sm tracking-tight">Welcome Back</h1>
            <p class="text-body-sm font-body-sm text-on-surface-variant">Sign in to manage your bookings and properties.</p>
        </div>

        @if (Model.Result is not null)
        {
            <div class="mb-stack-md rounded-lg border border-secondary-container bg-secondary-container p-stack-md text-body-sm text-on-secondary-container">
                Login OK. Token generated for @Model.Result.Email as @Model.Result.Role.
            </div>
            <pre class="mb-stack-md overflow-x-auto rounded-lg bg-surface-container-low p-stack-md text-xs">@Model.Result.Token</pre>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-stack-md rounded-lg border border-error/30 bg-error-container p-stack-md text-body-sm text-error">@Model.ErrorMessage</div>
        }

        <form class="flex flex-col gap-stack-md" method="post">
            <div class="space-y-1">
                <label class="text-label-md font-label-md text-on-surface block" asp-for="Email"></label>
                <input asp-for="Email" class="w-full px-3 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest" />
            </div>

            <div class="space-y-1">
                <label class="text-label-md font-label-md text-on-surface block" asp-for="Password"></label>
                <input asp-for="Password" class="w-full px-3 py-2 border border-outline-variant/50 rounded-lg text-body-md font-body-md text-on-surface bg-surface-container-lowest" type="password" />
            </div>

            <button class="mt-4 w-full bg-primary text-on-primary py-3 px-4 rounded-lg text-label-md font-label-md hover:bg-inverse-surface transition-all" type="submit">
                Sign In
            </button>
        </form>
    </div>
</main>
